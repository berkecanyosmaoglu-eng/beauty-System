generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * Existing core tables (from db pull):
 * Tenant, Service, Staff, Customer, Appointment, CallSession
 * We keep them and ADD new MVP bot tables additively.
 */

enum AppointmentStatus {
  scheduled
  cancelled
  done
}

enum Channel {
  VOICE
  WHATSAPP
  SMS
  WEB
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}



enum MessageRole {
  USER
  BOT
  SYSTEM
}

model Tenant {
  id           String        @id @default(cuid())
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  customers    Customer[]
  services     Service[]
  staff        Staff[]

  // ✅ new (no DB column here; relation only)
  business      Business?
  conversations BotConversation[]
  staffServices StaffService[]
}

model Service {
  id           String        @id @default(cuid())
  tenantId     String
  name         String
  price        Int
  duration     Int
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // ✅ new
  staffLinks StaffService[]

  @@unique([tenantId, name])
  @@index([tenantId])
}
model WhatsAppMessage {
  id           String           @id @default(cuid())
  tenantId     String
  direction    MessageDirection
  from         String?
  to           String?
  body         String?
  provider     String           @default("twilio")
  providerSid  String?
  createdAt    DateTime         @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, direction, createdAt])
}


model Staff {
  id           String        @id @default(cuid())
  tenantId     String
  fullName     String
  phone        String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // ✅ new
  services     StaffService[]
  workingHours WorkingHours[]
  timeOffs     TimeOff[]

  @@unique([tenantId, fullName])
  @@index([tenantId])
}

model Customer {
  id           String        @id @default(cuid())
  tenantId     String
  fullName     String
  phone        String
  note         String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // ✅ new (WhatsApp id/phone ayrı tutulabilir)
  whatsappPhone String?
  conversations BotConversation[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, whatsappPhone])
}

model Appointment {
  id         String            @id @default(cuid())
  tenantId   String
  customerId String
  serviceId  String
  startAt    DateTime
  endAt      DateTime
  status     AppointmentStatus @default(scheduled)

  // ✅ new: which channel created it
  channel Channel @default(WHATSAPP)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  staffId        String?
  reminderSentAt DateTime?
  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service        Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff          Staff?    @relation(fields: [staffId], references: [id])
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // (Optional) aynı staff+startAt duplicate’ini engeller (Postgres NULL staffId'e izin verir)
  @@unique([tenantId, staffId, startAt])
  @@index([customerId])
  @@index([serviceId])
  @@index([staffId])
  @@index([tenantId])
}

model CallSession {
  id        String   @id
  tenantId  String
  phone     String
  callSid   String
  step      String   @default("SERVICE")
  data      Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@unique([tenantId, callSid])
  @@index([tenantId, phone])
}

/**
 * =========================
 * ✅ NEW MVP BOT TABLES
 * =========================
 */

model Business {
  id       String @id @default(cuid())
  tenantId String @unique

  name     String
  phone    String?
  address  String?
  city     String?
  timezone String  @default("Europe/Istanbul")

  ownerName     String?
  ownerPhone    String? // SMS fallback
  ownerWhatsapp String? // WhatsApp primary

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model StaffService {
  id        String  @id @default(cuid())
  tenantId  String
  staffId   String
  serviceId String
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([tenantId, staffId, serviceId])
  @@index([tenantId])
  @@index([tenantId, staffId])
  @@index([tenantId, serviceId])
}

model WorkingHours {
  id       String @id @default(cuid())
  tenantId String
  staffId  String

  // ISO: 1=Mon ... 7=Sun
  dayOfWeek Int

  // minutes from 00:00 local time
  startMin Int
  endMin   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([tenantId, staffId, dayOfWeek, startMin, endMin])
  @@index([tenantId, staffId])
}

model TimeOff {
  id       String @id @default(cuid())
  tenantId String
  staffId  String

  startAt DateTime
  endAt   DateTime
  reason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([tenantId, staffId, startAt])
}

model BotConversation {
  id       String  @id @default(cuid())
  tenantId String
  channel  Channel

  customerId     String?
  externalUserId String? // WhatsApp "From" veya CallSid/phone
  isOpen         Boolean @default(true)

  state       String?
  contextJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  messages BotMessage[]

  @@index([tenantId, channel, isOpen])
  @@index([tenantId, externalUserId])
}

model BotMessage {
  id             String @id @default(cuid())
  tenantId       String
  conversationId String

  role    MessageRole
  text    String
  rawJson Json?

  createdAt DateTime @default(now())

  conversation BotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId, conversationId, createdAt])
}
model NotificationLog {
  id            String   @id @default(cuid())
  tenantId      String
  appointmentId String
  type          String   // e.g. "REMINDER_2H"
  to            String
  payload       Json?
  createdAt     DateTime @default(now())

  @@unique([appointmentId, type])
  @@index([tenantId, createdAt])
}

