import { Injectable, Logger } from '@nestjs/common';
import WebSocket from 'ws';
import { AgentService } from '../agent/agent.service';

/**
 * Twilio message payload type. Media events carry base64 encoded μ-law audio
 * while start/stop notify the stream SID.
 */
type TwilioMsg =
  | { event: 'connected' }
  | {
      event: 'start';
      start: {
        streamSid: string;
        callSid?: string;
        customParameters?: Record<string, string>;
      };
    }
  | { event: 'media'; streamSid: string; media: { payload: string } }
  | { event: 'stop'; streamSid: string };

type SessionState = {
  key: string; // internal map key
  tenantId: string;
  closed: boolean;

  // Twilio WS
  twilio?: WebSocket;
  streamSid?: string;
  twilioFrames: number;

  // OpenAI WS
  openai?: WebSocket;
  openaiReady: boolean;

  openaiAppends: number;
  openaiDeltas: number;
  openaiLastError?: string;

  // audio tracking (approx)
  appendedMsSinceCommit: number;

  // speaking / barge-in
  aiSpeaking: boolean; // true when we are currently streaming audio deltas to Twilio
  responseInProgress: boolean; // true after response.create until response.done
  aiHasActiveResponse: boolean; // true when response is active (created or delta started)

  // Debounce
  lastResponseCreateAt: number;

  // greet once
  greeted: boolean;

  // ✅ Enterprise: prevent "ghost audio" after cancel/clear
  dropAudioUntil: number; // epoch ms; while now < dropAudioUntil, ignore audio deltas
  lastBargeInAt: number; // epoch ms

  // ✅ Keepalive timers
  keepaliveTimer?: NodeJS.Timeout;
  openaiPingTimer?: NodeJS.Timeout;

  // ✅ Last transcript (for future brain hook / debugging)
  lastUserTranscript?: string;

  // ✅ Enterprise brain guards
  brainBusy: boolean;
  lastBrainAt: number;
  lastSpokenText?: string;
};

@Injectable()
export class RealtimeBridgeService {
  private readonly logger = new Logger(RealtimeBridgeService.name);
  private readonly sessions = new Map<string, SessionState>();

  constructor(private readonly agentService: AgentService) {}

  // OpenAI realtime endpoint + model query param
  private readonly openaiUrl =
    process.env.OPENAI_REALTIME_URL ||
    'wss://api.openai.com/v1/realtime?model=gpt-realtime-mini';

  private readonly apiKey = process.env.OPENAI_API_KEY || '';

  // keepalive intervals
  private readonly TWILIO_KEEPALIVE_MS = Number(process.env.TWILIO_KEEPALIVE_MS || 25000); // 25s
  private readonly OPENAI_PING_MS = Number(process.env.OPENAI_PING_MS || 20000); // 20s

  // cancel sonrası delta gelirse Twilio’ya kaçmasın diye drop penceresi
  private readonly DROP_AUDIO_AFTER_CANCEL_MS = Number(process.env.DROP_AUDIO_AFTER_CANCEL_MS || 800);

  // audio gating
  private readonly MIN_AUDIO_MS_FOR_COMMIT = Number(process.env.MIN_AUDIO_MS_FOR_COMMIT || 140);

  // Enterprise: transcript -> brain debounce
  private readonly BRAIN_DEBOUNCE_MS = Number(process.env.BRAIN_DEBOUNCE_MS || 250);

  /**
   * main.ts içindeki raw WS upgrade handler burayı çağırıyor.
   * - ws: Twilio Media Stream WebSocket
   * - requestUrl: örn "/bot/stream?tenantId=xxx"
   */
  handleTwilioWebSocket(ws: WebSocket, requestUrl: string) {
    const tenantIdFromQuery = this.getQueryParam(requestUrl, 'tenantId') || '';
    const tenantId = tenantIdFromQuery || 'default';

    // IMPORTANT: do NOT key sessions only by tenantId (parallel calls collide)
    const tempKey = `tmp:${tenantId}:${Date.now()}:${Math.random().toString(16).slice(2)}`;

    const state: SessionState = {
      key: tempKey,
      tenantId,
      closed: false,

      twilio: ws,
      streamSid: undefined,
      twilioFrames: 0,

      openai: undefined,
      openaiReady: false,
      openaiAppends: 0,
      openaiDeltas: 0,
      openaiLastError: undefined,

      appendedMsSinceCommit: 0,

      aiSpeaking: false,
      responseInProgress: false,
      aiHasActiveResponse: false,

      lastResponseCreateAt: 0,
      greeted: false,

      dropAudioUntil: 0,
      lastBargeInAt: 0,
      lastUserTranscript: undefined,

      brainBusy: false,
      lastBrainAt: 0,
      lastSpokenText: undefined,
    };

    this.sessions.set(tempKey, state);
    this.logger.log(`WS CONNECT url=${requestUrl} tenantId(query)=${tenantIdFromQuery || '-'}`);

    // ✅ Twilio keepalive (some proxies kill idle WS)
    state.keepaliveTimer = setInterval(() => {
      try {
        if (ws.readyState === WebSocket.OPEN) ws.ping();
      } catch {}
    }, this.TWILIO_KEEPALIVE_MS);

    ws.on('message', (raw) => {
      try {
        const msg = JSON.parse(String(raw)) as TwilioMsg;

        if (msg.event === 'start') {
          const streamSid = msg.start?.streamSid;
          const tenantIdFromStart = msg.start?.customParameters?.tenantId || '';
          const finalTenantId = tenantIdFromStart || tenantId;

          state.tenantId = finalTenantId;
          state.streamSid = streamSid;

          // Move session key to stable streamSid-based key
          const newKey = `sid:${finalTenantId}:${streamSid}`;
          this.sessions.delete(state.key);
          state.key = newKey;
          this.sessions.set(newKey, state);

          this.logger.log(
            `Twilio start tenantId=${state.tenantId} streamSid=${streamSid} customTenant=${tenantIdFromStart || '-'}`,
          );

          this.ensureOpenAI(state.key);
          return;
        }

        if (msg.event === 'media') {
          state.twilioFrames++;

          // Calculate ms from base64 μ-law at 8kHz (1 byte/sample).
          try {
            const payload = msg.media?.payload || '';
            const byteLen = Buffer.from(payload, 'base64').length;
            const ms = Math.round((byteLen / 8000) * 1000);
            state.appendedMsSinceCommit += ms;
          } catch {
            // ignore
          }

          // append audio to OpenAI input buffer
          if (state.openai && state.openaiReady) {
            state.openai.send(
              JSON.stringify({
                type: 'input_audio_buffer.append',
                audio: msg.media.payload, // base64 g711_ulaw
              }),
            );
            state.openaiAppends++;
          }

          if (state.twilioFrames === 1 || state.twilioFrames % 200 === 0) {
            this.logger.log(
              `Twilio media tenantId=${state.tenantId} frames=${state.twilioFrames} openaiReady=${state.openaiReady} appends=${state.openaiAppends}`,
            );
          }
          return;
        }

        if (msg.event === 'stop') {
          this.detach(state.key, 'twilio-stop');
          return;
        }
      } catch (e: any) {
        this.logger.error(`twilio message parse error: ${e?.message || e}`);
      }
    });

    ws.on('close', () => this.detach(state.key, 'twilio-close'));
    ws.on('error', (e) => this.detach(state.key, `twilio-error:${(e as any)?.message || e}`));
  }

  // --------------------------
  // OpenAI realtime
  // --------------------------

  private ensureOpenAI(sessionKey: string) {
    const state = this.sessions.get(sessionKey);
    if (!state || state.closed) return;

    if (!this.apiKey) {
      state.openaiLastError = 'OPENAI_API_KEY missing';
      this.logger.error(`OpenAI key missing. sessionKey=${sessionKey}`);
      return;
    }

    if (
      state.openai &&
      (state.openai.readyState === WebSocket.OPEN || state.openai.readyState === WebSocket.CONNECTING)
    ) {
      return;
    }

    const ws = new WebSocket(this.openaiUrl, {
      headers: {
        Authorization: `Bearer ${this.apiKey}`,
        'OpenAI-Beta': 'realtime=v1',
      },
    });

    state.openai = ws;
    state.openaiReady = false;

    ws.on('open', () => {
      state.openaiReady = true;
      this.logger.log(`OpenAI WS connected tenantId=${state.tenantId} sessionKey=${sessionKey}`);

      // ✅ OpenAI ping keepalive
      state.openaiPingTimer = setInterval(() => {
        try {
          if (ws.readyState === WebSocket.OPEN) ws.ping();
        } catch {}
      }, this.OPENAI_PING_MS);

      // ===============================
      // 🔥 PREMIUM VOICE + PERSONA
      // ===============================
      const VOICE = (process.env.OPENAI_REALTIME_VOICE || 'alloy').trim();
      const MODEL = (process.env.OPENAI_REALTIME_MODEL || 'gpt-realtime-mini').trim();
      const TRANSCRIBE_MODEL = (process.env.OPENAI_TRANSCRIBE_MODEL || 'whisper-1').trim();

      const premiumInstructions =
        [
          'Sen bir güzellik merkezi için "premium" resepsiyonist asistanısın.',
          'Türkçe konuş.',
          'Doğal, sıcak, akıcı konuş; robot gibi maddeler sayma.',
          'Cevapları kısa tut ama tek cümleye sıkıştırma: 1-3 kısa cümle ideal.',
          'Gereksiz açıklama yapma. Kullanıcının söylediğini kısaca teyit et ve net ilerle.',
          'Asla teknik detay/ID söyleme.',
          'Sakin tempo: doğal duraklama hissi ver, aşırı hızlı konuşma.',
          'Senin beyin katmanın "sistem"tir; sistemin verdiği cevabı en doğal şekilde seslendir.',
        ].join(' ');

      const sessionUpdate = {
        type: 'session.update',
        session: {
          model: MODEL,
          modalities: ['audio', 'text'],
          input_audio_format: 'g711_ulaw',
          output_audio_format: 'g711_ulaw',
          voice: VOICE,

          // ✅ get user transcript from audio
          input_audio_transcription: {
            model: TRANSCRIBE_MODEL,
          },

          // VAD + barge-in
          turn_detection: {
            type: 'server_vad',
            prefix_padding_ms: 250,
            silence_duration_ms: 500,
            create_response: false, // IMPORTANT: we do NOT auto-create responses. Brain triggers speak.
            interrupt_response: true,
          },

          instructions: premiumInstructions,
        },
      };

      this.logger.log(
        `[RealtimeBridgeService] session.update tenantId=${state.tenantId} model=${MODEL} voice=${VOICE} transcribe=${TRANSCRIBE_MODEL}`,
      );
      ws.send(JSON.stringify(sessionUpdate));

      // ✅ Greeting (enterprise: speak fixed text, not free-gen)
      if (!state.greeted) {
        state.greeted = true;
        this.speakText(state, 'Merhaba, hoş geldiniz. Size nasıl yardımcı olabilirim?');
      }
    });

    ws.on('message', (raw) => {
      // async flow without making ws.on('message') async
      void this.onOpenAIMessage(sessionKey, raw);
    });

    ws.on('close', () => this.detach(sessionKey, 'openai-close'));
    ws.on('error', (e) => this.detach(sessionKey, `openai-error:${(e as any)?.message || e}`));
  }

  private async onOpenAIMessage(sessionKey: string, raw: WebSocket.RawData) {
    let msg: any;
    try {
      msg = JSON.parse(String(raw));
    } catch {
      return;
    }

    const t = msg?.type;
    const s = this.sessions.get(sessionKey);
    if (!s || s.closed) return;

    // Low-noise log for key events
    if (
      t === 'error' ||
      t === 'session.created' ||
      t === 'session.updated' ||
      t === 'response.created' ||
      t === 'response.done' ||
      t === 'input_audio_buffer.speech_started' ||
      t === 'input_audio_buffer.speech_stopped' ||
      t === 'conversation.item.input_audio_transcription.completed'
    ) {
      this.logger.log(`OpenAI event tenantId=${s.tenantId} type=${t}`);
    }

    if (t === 'error') {
      const em = msg?.error?.message || JSON.stringify(msg);
      this.logger.error(`OpenAI error tenantId=${s.tenantId}: ${em}`);

      s.openaiLastError = em;

      try {
        s.openai?.send(JSON.stringify({ type: 'input_audio_buffer.clear' }));
      } catch {}

      s.appendedMsSinceCommit = 0;
      s.responseInProgress = false;
      s.aiSpeaking = false;
      s.aiHasActiveResponse = false;
      return;
    }

    // ✅ transcript ready (user said...) -> Enterprise brain hook
    if (t === 'conversation.item.input_audio_transcription.completed') {
      const text =
        msg?.transcript ||
        msg?.item?.content?.[0]?.transcript ||
        msg?.content?.[0]?.transcript ||
        '';

      const userText = typeof text === 'string' ? text.trim() : '';
      if (!userText) return;

      s.lastUserTranscript = userText;
      this.logger.log(`[USER_TRANSCRIPT] tenantId=${s.tenantId} text="${userText}"`);

      // Debounce + avoid re-entrancy
      const now = Date.now();
      if (s.brainBusy) return;
      if (now - s.lastBrainAt < this.BRAIN_DEBOUNCE_MS) return;

      s.lastBrainAt = now;
      s.brainBusy = true;

      try {
        const reply = await this.askBrain(s, userText);
        this.speakText(s, reply);
      } catch (e: any) {
        this.logger.error(`[BRAIN_ERROR] tenantId=${s.tenantId} err=${e?.message || e}`);
        this.speakText(s, 'Bir saniye… teknik bir sorun oldu. Tekrar söyler misiniz?');
      } finally {
        s.brainBusy = false;
      }
      return;
    }

    // --------------------------
    // 🔥 BARGE-IN
    // --------------------------
    if (t === 'input_audio_buffer.speech_started') {
      const now = Date.now();
      s.lastBargeInAt = now;

      this.logger.log(
        `[BARGE-IN] speech_started tenantId=${s.tenantId} aiSpeaking=${s.aiSpeaking} active=${s.aiHasActiveResponse}`,
      );

      // ✅ After cancel/clear, drop any late deltas for a short window
      s.dropAudioUntil = now + this.DROP_AUDIO_AFTER_CANCEL_MS;

      if (s.aiHasActiveResponse) {
        try {
          s.openai?.send(JSON.stringify({ type: 'response.cancel' }));
        } catch {}
      }

      // Clear buffers both sides
      try {
        s.openai?.send(JSON.stringify({ type: 'input_audio_buffer.clear' }));
      } catch {}

      if (s.twilio && s.streamSid) {
        try {
          s.twilio.send(JSON.stringify({ event: 'clear', streamSid: s.streamSid }));
        } catch {}
      }

      // reset local flags
      s.appendedMsSinceCommit = 0;
      s.aiSpeaking = false;
      s.responseInProgress = false;
      s.aiHasActiveResponse = false;
      return;
    }

    /**
     * ✅ Enterprise change:
     * speech_stopped -> ONLY commit.
     * We DO NOT response.create here. Brain triggers speak after transcript is ready.
     */
    if (t === 'input_audio_buffer.speech_stopped') {
      if (!s.openai || !s.openaiReady) return;

      const ok = this.hasEnoughAudio(s, 'speech_stopped');
      if (!ok) return;

      try {
        s.openai.send(JSON.stringify({ type: 'input_audio_buffer.commit' }));
      } catch {}

      s.appendedMsSinceCommit = 0;
      this.logger.log(`input_audio_buffer.commit tenantId=${s.tenantId}`);
      return;
    }

    // Response done -> reset flags
    if (
      t === 'response.done' ||
      t === 'response.audio.done' ||
      t === 'response.output_audio.done' ||
      t === 'response.end'
    ) {
      s.aiSpeaking = false;
      s.responseInProgress = false;
      s.aiHasActiveResponse = false;
      return;
    }

    // OpenAI audio delta -> forward to Twilio
    if (t === 'response.audio.delta' || t === 'response.output_audio.delta') {
      const delta = msg?.delta;

      // ✅ If we recently barged-in, ignore late deltas (prevents ghost audio)
      const now = Date.now();
      if (now < (s.dropAudioUntil || 0)) return;

      // mark as speaking
      s.aiHasActiveResponse = true;
      s.aiSpeaking = true;

      if (typeof delta === 'string' && s.twilio && s.streamSid) {
        s.openaiDeltas++;
        try {
          s.twilio.send(
            JSON.stringify({
              event: 'media',
              streamSid: s.streamSid,
              media: { payload: delta },
            }),
          );
        } catch {}

        if (s.openaiDeltas === 1 || s.openaiDeltas % 50 === 0) {
          this.logger.log(
            `OpenAI audio.delta tenantId=${s.tenantId} deltas=${s.openaiDeltas} twilioFrames=${s.twilioFrames}`,
          );
        }
      }
      return;
    }

    // response.created can happen (we create them in speakText)
    if (t === 'response.created') {
      s.responseInProgress = true;
      s.aiHasActiveResponse = true;
      return;
    }
  }

  /**
   * Enterprise: speak a fixed assistant text through realtime TTS.
   * - Creates assistant message item
   * - Creates response for audio synthesis
   */
  private speakText(session: SessionState, text: string) {
    if (!session.openai || !session.openaiReady) return;

    const clean = (text || '').trim();
    if (!clean) return;

    // avoid repeating identical output back-to-back
    if (session.lastSpokenText && session.lastSpokenText.trim() === clean) return;
    session.lastSpokenText = clean;

    // Mark active response
    session.responseInProgress = true;
    session.aiHasActiveResponse = true;
    session.aiSpeaking = false;
    session.lastResponseCreateAt = Date.now();

    try {
      session.openai.send(
        JSON.stringify({
          type: 'conversation.item.create',
          item: {
            type: 'message',
            role: 'assistant',
            content: [{ type: 'output_text', text: clean }],
          },
        }),
      );
    } catch {}

    try {
      session.openai.send(
        JSON.stringify({
          type: 'response.create',
          response: {
            modalities: ['audio', 'text'],
          },
        }),
      );
    } catch {}

    this.logger.log(`[JARVIS_SPEAK] tenantId=${session.tenantId} text="${clean}"`);
  }

  /**
   * Enterprise brain: call AgentService with best-effort method detection.
   * Returns a string reply safe to speak.
   */
  private async askBrain(session: SessionState, userText: string): Promise<string> {
    const tenantId = session.tenantId || 'default';
    const from = `voice:${session.streamSid || 'unknown'}`;

    const payloadA: any = { tenantId, phone: from, from, text: userText, channel: 'VOICE' };
    const payloadB: any = { tenantId, from, text: userText };
    const payloadC: any = { tenantId, customerPhone: from, text: userText };

    const svc: any = this.agentService as any;

    const candidates: Array<[string, (...args: any[]) => any, any[]]> = [];

    if (typeof svc?.handleIncoming === 'function') candidates.push(['handleIncoming', svc.handleIncoming.bind(svc), [payloadA]]);
    if (typeof svc?.onIncoming === 'function') candidates.push(['onIncoming', svc.onIncoming.bind(svc), [payloadA]]);
    if (typeof svc?.processIncoming === 'function') candidates.push(['processIncoming', svc.processIncoming.bind(svc), [payloadA]]);
    if (typeof svc?.handleMessage === 'function') candidates.push(['handleMessage', svc.handleMessage.bind(svc), [payloadB]]);
    if (typeof svc?.reply === 'function') candidates.push(['reply', svc.reply.bind(svc), [payloadB]]);
    if (typeof svc?.run === 'function') candidates.push(['run', svc.run.bind(svc), [payloadB]]);

    // Also try common signatures: (tenantId, from, text)
    if (typeof svc?.handleIncoming === 'function') candidates.push(['handleIncoming(3)', svc.handleIncoming.bind(svc), [tenantId, from, userText]]);
    if (typeof svc?.handleMessage === 'function') candidates.push(['handleMessage(3)', svc.handleMessage.bind(svc), [tenantId, from, userText]]);

    let lastErr: any = null;

    for (const [name, fn, args] of candidates) {
      try {
        const out = await fn(...args);

        // normalize output
        const spoken =
          typeof out === 'string'
            ? out
            : (out?.reply ?? out?.message ?? out?.text ?? out?.output ?? '');

        const clean = String(spoken || '').trim();
        if (clean) {
          this.logger.log(`[BRAIN_OK] tenantId=${tenantId} method=${name}`);
          return clean;
        }
      } catch (e: any) {
        lastErr = e;
        this.logger.warn(`[BRAIN_TRY_FAIL] tenantId=${tenantId} method=${name} err=${e?.message || e}`);
      }
    }

    this.logger.error(
      `[BRAIN_FAIL] tenantId=${tenantId} err=${lastErr?.message || lastErr || 'no_method_or_empty_reply'}`,
    );

    return 'Şu an kısa bir teknik sorun yaşıyorum. Bir kez daha söyler misiniz?';
  }

  // --------------------------
  // Helpers / cleanup
  // --------------------------

  private detach(sessionKey: string, reason: string) {
    const state = this.sessions.get(sessionKey);
    if (!state || state.closed) return;

    state.closed = true;

    this.logger.warn(
      `Bridge close tenantId=${state.tenantId} sessionKey=${sessionKey} reason=${reason} twilioFrames=${state.twilioFrames} openaiAppends=${state.openaiAppends} openaiDeltas=${state.openaiDeltas} openaiErr=${state.openaiLastError || '-'}`,
    );

    // ✅ clear timers
    try {
      if (state.keepaliveTimer) clearInterval(state.keepaliveTimer);
    } catch {}
    try {
      if (state.openaiPingTimer) clearInterval(state.openaiPingTimer);
    } catch {}

    try {
      state.openai?.close();
    } catch {}
    try {
      state.twilio?.close();
    } catch {}

    this.sessions.delete(sessionKey);
  }

  private getQueryParam(url: string, key: string): string | null {
    const idx = url.indexOf('?');
    if (idx === -1) return null;
    const qs = url.slice(idx + 1);
    for (const part of qs.split('&')) {
      const [k, v] = part.split('=');
      if (k === key) return decodeURIComponent(v || '');
    }
    return null;
  }

  private hasEnoughAudio(session: SessionState, reason: string): boolean {
    const ms = session.appendedMsSinceCommit || 0;

    if (ms < this.MIN_AUDIO_MS_FOR_COMMIT) {
      this.logger.warn(
        `[RealtimeBridgeService] skip commit (audio too short) why=${reason} ms=${ms} tenantId=${session.tenantId}`,
      );
      try {
        session.openai?.send(JSON.stringify({ type: 'input_audio_buffer.clear' }));
      } catch {}
      session.appendedMsSinceCommit = 0;
      return false;
    }

    this.logger.log(
      `[RealtimeBridgeService] ok for commit why=${reason} ms=${ms} tenantId=${session.tenantId}`,
    );
    return true;
  }
}
