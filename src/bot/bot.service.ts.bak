import { BadRequestException, Injectable } from '@nestjs/common';
import { PrismaService } from '../prisma/prisma.service';
import OpenAI from 'openai';

type Step = 'SERVICE' | 'STAFF' | 'DATE' | 'TIME' | 'CONFIRM';

@Injectable()
export class BotService {
  constructor(private readonly prisma: PrismaService) {}

  private openai = new OpenAI({
    apiKey: process.env.OPENAI_API_KEY,
  });

async handleVoice(params: {
  tenantId: string;
  callSid: string;
  from: string;
  input: string | null;
  inputType: 'dtmf' | 'speech' | null;
}): Promise<string> {
  const { tenantId, callSid, from, input, inputType } = params;

  // 1) Tenant doğrula
  const tenant = await this.prisma.tenant.findUnique({
    where: { id: tenantId },
    select: { id: true },
  });
  if (!tenant) throw new BadRequestException('tenantId gecersiz');

  // 2) Session getir/oluştur (tenantId + callSid unique)
  const session = await this.prisma.callSession.upsert({
    where: { tenantId_callSid: { tenantId, callSid } },
    create: {
      tenantId,
      callSid,
      phone: from,
      step: 'SERVICE',
      data: {},
    },
    update: { phone: from },
  });

  // 3) SPEECH ise AI
  if (inputType === 'speech' && input) {
    return this.answerWithAI(tenantId, input, session);
  }

  // 4) DTMF akışı
  return this.handleDtmfFlow(tenantId, session, input);
}

    // 3) SPEECH (AI / Q&A) ROUTER
    const said = (speech || '').toLowerCase().trim();

    if (speech && !digits) {
      const isBooking =
        said.includes('randevu') ||
        said.includes('rezervasyon') ||
        said.includes('saat') ||
        said.includes('bugün') ||
        said.includes('yarın') ||
        said.includes('müsait') ||
        said.includes('uygun');

      // rezervasyon değilse AI ile cevapla
      if (!isBooking) {
        const answer = await this.answerWithAI(tenantId, said, session);
        return this.twimlSay('tr-TR', answer);
      }
    }

    // 4) Step & data
    const step = ((session.step as Step) ?? 'SERVICE') as Step;
    const data = (session.data as any) || {};

    // ======================
    // STEP: SERVICE
    // ======================
    if (step === 'SERVICE') {
      const services = await this.prisma.service.findMany({
        where: { tenantId },
        select: { id: true, name: true },
        take: 9,
      });

      if (!services.length) {
        return this.twimlSay(
          'tr-TR',
          'Sistemde henüz hizmet tanımlı değil. Lütfen daha sonra tekrar deneyin.',
        );
      }

      if (!digits) {
        const menuText = services.map((s, i) => `${i + 1}: ${s.name}.`).join(' ');
        return this.twimlGather(tenantId, `Merhaba. Hizmet seçiniz. ${menuText}`, 1);
      }

      const idx = Number(digits) - 1;
      const selected = Number.isInteger(idx) ? services[idx] : null;

      if (!selected) {
        return this.twimlGather(tenantId, 'Geçersiz seçim. Lütfen tekrar deneyin.', 1);
      }

      await this.prisma.callSession.update({
        where: { id: session.id },
        data: {
          step: 'STAFF',
          data: {
            ...data,
            serviceId: selected.id,
            serviceName: selected.name,
          },
        },
      });

      return this.twimlGather(tenantId, `Seçtiniz: ${selected.name}. Şimdi personel seçiniz.`, 1);
    }

    // ======================
    // STEP: STAFF
    // ======================
    if (step === 'STAFF') {
      // service seçili mi?
      if (!data.serviceId) {
        await this.resetSessionToService(session.id);
        return this.twimlGather(tenantId, 'Eksik bilgi var. Baştan başlayalım. Hizmet seçiniz.', 1);
      }

      const staffList = await this.getStaffListSafe(tenantId);
      if (!staffList.length) {
        await this.resetSessionToService(session.id);
        return this.twimlSay('tr-TR', 'Sistemde personel tanımlı değil.');
      }

      if (!digits) {
        const menuText = staffList
          .slice(0, 9)
          .map((s: any, i: number) => `${i + 1}: ${this.staffDisplayName(s)}.`)
          .join(' ');
        return this.twimlGather(tenantId, `Personel seçiniz. ${menuText}`, 1);
      }

      const idx = Number(digits) - 1;
      const selected = Number.isInteger(idx) ? staffList[idx] : null;

      if (!selected) {
        return this.twimlGather(tenantId, 'Geçersiz seçim. Lütfen tekrar deneyin.', 1);
      }

      await this.prisma.callSession.update({
        where: { id: session.id },
        data: {
          step: 'DATE',
          data: {
            ...data,
            staffId: selected.id,
            staffName: this.staffDisplayName(selected),
          },
        },
      });

      const dateOptions = this.getDateOptionsTR(); // [{label, iso}]
      const menu = dateOptions.map((d, i) => `${i + 1}: ${d.label}.`).join(' ');
      return this.twimlGather(
        tenantId,
        `Personel seçildi: ${this.staffDisplayName(selected)}. Tarih seçiniz. ${menu}`,
        1,
      );
    }

    // ======================
    // STEP: DATE
    // ======================
    if (step === 'DATE') {
      if (!data.serviceId || !data.staffId) {
        await this.resetSessionToService(session.id);
        return this.twimlGather(tenantId, 'Eksik bilgi var. Baştan başlayalım. Hizmet seçiniz.', 1);
      }

      const dateOptions = this.getDateOptionsTR(); // 3 seçenek
      if (!digits) {
        const menu = dateOptions.map((d, i) => `${i + 1}: ${d.label}.`).join(' ');
        return this.twimlGather(tenantId, `Tarih seçiniz. ${menu}`, 1);
      }

      const idx = Number(digits) - 1;
      const selected = Number.isInteger(idx) ? dateOptions[idx] : null;
      if (!selected) return this.twimlGather(tenantId, 'Geçersiz seçim. Tarih seçiniz.', 1);

      await this.prisma.callSession.update({
        where: { id: session.id },
        data: {
          step: 'TIME',
          data: {
            ...data,
            dateISO: selected.iso,
            dateLabel: selected.label,
          },
        },
      });

      const slots = this.getTimeSlots(); // ["09:00", ...]
      const menu = slots.map((t, i) => `${i + 1}: ${t}.`).join(' ');
      return this.twimlGather(tenantId, `Saat seçiniz. ${menu}`, 1);
    }

    // ======================
    // STEP: TIME
    // ======================
    if (step === 'TIME') {
      if (!data.serviceId || !data.staffId || !data.dateISO) {
        await this.resetSessionToService(session.id);
        return this.twimlGather(tenantId, 'Eksik bilgi var. Baştan başlayalım. Hizmet seçiniz.', 1);
      }

      const slots = this.getTimeSlots();
      if (!digits) {
        const menu = slots.map((t, i) => `${i + 1}: ${t}.`).join(' ');
        return this.twimlGather(tenantId, `Saat seçiniz. ${menu}`, 1);
      }

      const idx = Number(digits) - 1;
      const selected = Number.isInteger(idx) ? slots[idx] : null;
      if (!selected) return this.twimlGather(tenantId, 'Geçersiz seçim. Saat seçiniz.', 1);

      await this.prisma.callSession.update({
        where: { id: session.id },
        data: {
          step: 'CONFIRM',
          data: {
            ...data,
            timeHHmm: selected,
          },
        },
      });

      const summary = this.buildSummaryTR(data.serviceName, data.staffName, data.dateLabel, selected);
      return this.twimlGather(tenantId, `${summary} Onaylıyor musunuz? 1: Evet. 2: Baştan başla.`, 1);
    }

    // ======================
    // STEP: CONFIRM
    // ======================
    if (step === 'CONFIRM') {
      if (!data.serviceId || !data.dateISO || !data.timeHHmm) {
        await this.resetSessionToService(session.id);
        return this.twimlGather(tenantId, 'Eksik bilgi var. Baştan başlayalım. Hizmet seçiniz.', 1);
      }

      if (!digits) {
        const summary = this.buildSummaryTR(
          data.serviceName,
          data.staffName,
          data.dateLabel,
          data.timeHHmm,
        );
        return this.twimlGather(tenantId, `${summary} Onaylıyor musunuz? 1: Evet. 2: Baştan başla.`, 1);
      }

      if (digits === '2') {
        await this.resetSessionToService(session.id);
        return this.twimlGather(tenantId, 'Baştan başlıyoruz. Hizmet seçiniz.', 1);
      }

      if (digits !== '1') {
        return this.twimlGather(tenantId, 'Geçersiz seçim. 1: Evet. 2: Baştan başla.', 1);
      }

      // Appointment create
      const startsAt = this.makeDateTimeTR(data.dateISO, data.timeHHmm);
      const endsAt = new Date(startsAt.getTime() + 60 * 60 * 1000); // 1 saat

      const created = await this.createAppointmentSafe({
        tenantId,
        serviceId: data.serviceId,
        staffId: data.staffId || null,
        phone: from,
        startsAt,
        endsAt,
      });

      if (!created.ok) {
        return this.twimlSay(
          'tr-TR',
          `Randevu kaydı oluşturulamadı. (${created.reason}) Panelden kontrol edelim. Tekrar denemek için arayın.`,
        );
      }

      // Session sıfırla
      await this.prisma.callSession.update({
        where: { id: session.id },
        data: { step: 'SERVICE', data: {} },
      });

      return this.twimlSay('tr-TR', 'Randevunuz oluşturuldu. Teşekkürler!');
    }

    return this.twimlSay('tr-TR', 'Akış devam ediyor.');
  }

  // ---------- Helpers ----------
  private async resetSessionToService(sessionId: string) {
    await this.prisma.callSession.update({
      where: { id: sessionId },
      data: { step: 'SERVICE', data: {} },
    });
  }

  private async getStaffListSafe(tenantId: string): Promise<any[]> {
    try {
      return await (this.prisma as any).staff.findMany({
        where: { tenantId, isActive: true },
        select: { id: true, fullName: true },
        take: 9,
      });
    } catch {
      // bazı projelerde alan farklı olabilir diye fallback
      return await (this.prisma as any).staff.findMany({
        where: { tenantId },
        select: { id: true, fullName: true },
        take: 9,
      });
    }
  }

  private staffDisplayName(s: any): string {
    return s?.fullName || s?.name || s?.title || 'Personel';
  }

  private getDateOptionsTR() {
    const today = new Date();
    const d1 = this.formatDateISO(today);
    const d2 = this.formatDateISO(this.addDays(today, 1));
    const d3 = this.formatDateISO(this.addDays(today, 2));

    return [
      { label: `Bugün (${this.prettyTR(today)})`, iso: d1 },
      { label: `Yarın (${this.prettyTR(this.addDays(today, 1))})`, iso: d2 },
      { label: `Öbür gün (${this.prettyTR(this.addDays(today, 2))})`, iso: d3 },
    ];
  }

  private getTimeSlots() {
    return ['09:00', '10:00', '11:00', '12:00', '13:00', '14:00', '15:00', '16:00', '17:00'];
  }

  private buildSummaryTR(serviceName?: string, staffName?: string, dateLabel?: string, time?: string) {
    const s = serviceName || 'Hizmet';
    const p = staffName || 'Personel';
    const d = dateLabel || 'Tarih';
    const t = time || 'Saat';
    return `Özet: ${s}. Personel: ${p}. ${d}. Saat: ${t}.`;
  }

  private makeDateTimeTR(dateISO: string, hhmm: string) {
    // Türkiye offset +03:00
    return new Date(`${dateISO}T${hhmm}:00+03:00`);
  }

  private addDays(d: Date, days: number) {
    const x = new Date(d.getTime());
    x.setDate(x.getDate() + days);
    return x;
  }

  private formatDateISO(d: Date) {
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${y}-${m}-${day}`;
  }

  private prettyTR(d: Date) {
    try {
      return new Intl.DateTimeFormat('tr-TR', { day: '2-digit', month: 'long' }).format(d);
    } catch {
      return this.formatDateISO(d);
    }
  }

  private async createAppointmentSafe(args: {
    tenantId: string;
    serviceId: string;
    staffId: string | null;
    phone: string;
    startsAt: Date;
    endsAt: Date;
  }): Promise<{ ok: boolean; reason?: string }> {
    try {
      // Customer find-or-create by phone
      let customerId: string | null = null;

      const existing = await (this.prisma as any).customer.findFirst({
        where: { tenantId: args.tenantId, phone: args.phone },
        select: { id: true },
      });
      if (existing?.id) customerId = existing.id;

      if (!customerId) {
        const createdCustomer = await (this.prisma as any).customer.create({
          data: {
            tenantId: args.tenantId,
            fullName: args.phone,
            phone: args.phone,
          },
          select: { id: true },
        });
        customerId = createdCustomer.id;
      }

      // Clash check (same staff, overlapping time) - if staff is selected
      if (args.staffId) {
        const clash = await (this.prisma as any).appointment.findFirst({
          where: {
            tenantId: args.tenantId,
            staffId: args.staffId,
            startAt: { lt: args.endsAt },
            endAt: { gt: args.startsAt },
          },
          select: { id: true },
        });
        if (clash?.id) return { ok: false, reason: 'Seçilen saatte dolu' };
      }

      await (this.prisma as any).appointment.create({
        data: {
          tenantId: args.tenantId,
          customerId,
          serviceId: args.serviceId,
          staffId: args.staffId,
          startAt: args.startsAt,
          endAt: args.endsAt,
          status: 'scheduled',
        },
      });

      return { ok: true };
    } catch (e: any) {
      return { ok: false, reason: e?.message || 'Hata' };
    }
  }

  // ---------- AI ----------
   private async answerWithAI(tenantId: string, said: string, session: any) {
    const services = await this.prisma.service.findMany({

      where: { tenantId },
      select: { name: true },
  
  });

    const staff = await this.prisma.staff.findMany({
      where: { tenantId, isActive: true },
      select: { fullName: true },
    });

    const systemPrompt = `
Sen bir güzellik merkezi için çalışan profesyonel, samimi bir telefon asistanısın.
Kısa, net ve doğal cevap ver. Satışçı gibi konuşma.

Kurallar:
- Türkçe konuş
- En fazla 2 cümle
- Kullanıcı bilgi soruyorsa net cevap ver
- Uygunsa "istersen randevu da oluşturabilirim" diye nazikçe ekle

Mevcut hizmetler:
${services.map(s => `- ${s.name}`).join('\n') || 'Tanımlı değil'}

Mevcut personeller:
${staff.map(s => `- ${s.fullName}`).join('\n') || 'Tanımlı değil'}
`.trim();

    try {
      const completion = await this.openai.chat.completions.create({
        model: 'gpt-4o-mini',
        temperature: 0.4,
        messages: [
          { role: 'system', content: systemPrompt },
          { role: 'user', content: said },
        ],
      });

      return (
        completion.choices[0]?.message?.content?.trim() ||
        'Bu konuda yardımcı olabilirim. İstersen randevu da oluşturabilirim.'
      );
} catch (e: any) {
  console.error('AI_ERROR:', e?.message || e);
  return 'Şu an bu soruya cevap veremiyorum. İstersen randevu da oluşturabiliriz.';
}
  }

  // ---------- TwiML ----------
  private twimlGather(tenantId: string, sayText: string, numDigits: number) {
    const baseUrl = (process.env.BOT_BASE_URL || '').replace(/\/$/, '');
    const action = baseUrl
      ? `${baseUrl}/bot/voice?tenantId=${encodeURIComponent(tenantId)}`
      : `/bot/voice?tenantId=${encodeURIComponent(tenantId)}`;

    return `<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Gather
    input="speech dtmf"
    speechTimeout="auto"
    numDigits="${numDigits ?? 1}"
    timeout="6"
    action="${action}"
    method="POST"
    language="tr-TR"
  >
    <Say language="tr-TR">${this.escapeXml(sayText)}</Say>
  </Gather>
  <Say language="tr-TR">Yanıt alamadım. Hoşça kal.</Say>
</Response>`;
  }

  private twimlSay(lang: string, text: string) {
    return `<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Say language="${lang}">${this.escapeXml(text)}</Say>
</Response>`;
  }
private handleDtmfFlow(session: any, input: string | null): string {
  return `
<Response>
  <Say voice="Polly.Ayse">
    Tuşlama algılandı. Devam ediliyor.
  </Say>
  <Gather input="speech dtmf" timeout="5" />
</Response>
`;
}

  private escapeXml(str: string) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&apos;');
  }
}
