private sanitizeForTwilioText(input: string) {
  if (!input) return '';
  let s = String(input);

  // control chars temizle
  s = s.replace(/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F]/g, ' ');

  // whitespace normalize
  s = s.replace(/\s+/g, ' ').trim();

  // çok uzunsa kısalt
  if (s.length > 900) s = s.slice(0, 900);

  return s;
}

private escapeForSsmlText(input: string) {
  const s = this.sanitizeForTwilioText(input);
  return this.escapeXml(s);
}

private escapeXml(str: string) {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&apos;');
}
