import { Injectable, Logger } from '@nestjs/common';
import WebSocket from 'ws';

/**
 * Twilio message payload type. Media events carry base64 encoded μ-law audio
 * while start/stop notify the stream SID.
 */
type TwilioMsg =
  | { event: 'connected' }
  | {
      event: 'start';
      start: {
        streamSid: string;
        callSid?: string;
        customParameters?: Record<string, string>;
      };
    }
  | { event: 'media'; streamSid: string; media: { payload: string } }
  | { event: 'stop'; streamSid: string };

type SessionState = {
  key: string;
  tenantId: string;
  closed: boolean;

  // Twilio WS
  twilio?: WebSocket;
  streamSid?: string;
  twilioFrames: number;

  // OpenAI WS
  openai?: WebSocket;
  openaiReady: boolean;

  openaiAppends: number;
  openaiDeltas: number;
  openaiLastError?: string;

  // ✅ Track audio that was ACTUALLY appended to OpenAI
  openaiBufferedMs: number;

  // speaking / barge-in
  aiSpeaking: boolean;
  responseInProgress: boolean;
  aiHasActiveResponse: boolean;

  // Debounce
  lastResponseCreateAt: number;

  // greet once
  greeted: boolean;

  // prevent ghost audio after cancel/clear
  dropAudioUntil: number;
  lastBargeInAt: number;

  // Keepalive timers
  keepaliveTimer?: NodeJS.Timeout;
  openaiPingTimer?: NodeJS.Timeout;

  // Reconnect control
  openaiReconnectTimer?: NodeJS.Timeout;
  openaiReconnectAttempts: number;
  openaiLastDisconnectAt: number;

  // Last transcript (debug)
  lastUserTranscript?: string;
};

@Injectable()
export class RealtimeBridgeService {
  private readonly logger = new Logger(RealtimeBridgeService.name);
  private readonly sessions = new Map<string, SessionState>();

  private readonly openaiUrl =
    process.env.OPENAI_REALTIME_URL ||
    'wss://api.openai.com/v1/realtime?model=gpt-4o-realtime-preview';

  private readonly apiKey = process.env.OPENAI_API_KEY || '';

  // keepalive intervals
  private readonly TWILIO_KEEPALIVE_MS = Number(process.env.TWILIO_KEEPALIVE_MS || 25000);
  private readonly OPENAI_PING_MS = Number(process.env.OPENAI_PING_MS || 20000);

  // cancel sonrası delta gelirse Twilio’ya kaçmasın diye drop penceresi
  private readonly DROP_AUDIO_AFTER_CANCEL_MS = Number(process.env.DROP_AUDIO_AFTER_CANCEL_MS || 900);

  // ✅ Commit guard (OpenAI gerçek buffer ms)
  private readonly MIN_OPENAI_BUFFER_MS = Number(process.env.MIN_OPENAI_BUFFER_MS || 220);

  // ✅ response.create debounce (latency azaltıyoruz)
  private readonly RESPONSE_CREATE_DEBOUNCE_MS = Number(process.env.RESPONSE_CREATE_DEBOUNCE_MS || 250);

  // reconnect
  private readonly OPENAI_RECONNECT_MAX = Number(process.env.OPENAI_RECONNECT_MAX || 8);
  private readonly OPENAI_RECONNECT_BASE_MS = Number(process.env.OPENAI_RECONNECT_BASE_MS || 500);
  private readonly OPENAI_RECONNECT_MAX_MS = Number(process.env.OPENAI_RECONNECT_MAX_MS || 6000);

  handleTwilioWebSocket(ws: WebSocket, requestUrl: string) {
    const tenantIdFromQuery = this.getQueryParam(requestUrl, 'tenantId') || '';
    const tenantId = tenantIdFromQuery || 'default';
    const tempKey = `tmp:${tenantId}:${Date.now()}:${Math.random().toString(16).slice(2)}`;

    const state: SessionState = {
      key: tempKey,
      tenantId,
      closed: false,

      twilio: ws,
      streamSid: undefined,
      twilioFrames: 0,

      openai: undefined,
      openaiReady: false,
      openaiAppends: 0,
      openaiDeltas: 0,
      openaiLastError: undefined,

      openaiBufferedMs: 0,

      aiSpeaking: false,
      responseInProgress: false,
      aiHasActiveResponse: false,

      lastResponseCreateAt: 0,
      greeted: false,

      dropAudioUntil: 0,
      lastBargeInAt: 0,

      openaiReconnectAttempts: 0,
      openaiLastDisconnectAt: 0,

      lastUserTranscript: undefined,
    };

    this.sessions.set(tempKey, state);
    this.logger.log(`WS CONNECT url=${requestUrl} tenantId(query)=${tenantIdFromQuery || '-'}`);

    state.keepaliveTimer = setInterval(() => {
      try {
        if (ws.readyState === WebSocket.OPEN) ws.ping();
      } catch {}
    }, this.TWILIO_KEEPALIVE_MS);

    ws.on('message', (raw) => {
      try {
        const msg = JSON.parse(String(raw)) as TwilioMsg;

        if (msg.event === 'start') {
          const streamSid = msg.start?.streamSid;
          const tenantIdFromStart = msg.start?.customParameters?.tenantId || '';
          const finalTenantId = tenantIdFromStart || tenantId;

          state.tenantId = finalTenantId;
          state.streamSid = streamSid;

          const newKey = `sid:${finalTenantId}:${streamSid}`;
          this.sessions.delete(state.key);
          state.key = newKey;
          this.sessions.set(newKey, state);

          this.logger.log(
            `Twilio start tenantId=${state.tenantId} streamSid=${streamSid} customTenant=${tenantIdFromStart || '-'}`
          );

          this.ensureOpenAI(state.key);
          return;
        }

        if (msg.event === 'media') {
          state.twilioFrames++;

          const payload = msg.media?.payload || '';
          let ms = 0;

          // 8kHz g711 ulaw: 8000 bytes/sec
          try {
            const byteLen = Buffer.from(payload, 'base64').length;
            ms = Math.round((byteLen / 8000) * 1000);
          } catch {}

          if (state.openai && state.openaiReady) {
            try {
              state.openai.send(
                JSON.stringify({
                  type: 'input_audio_buffer.append',
                  audio: payload,
                }),
              );
              state.openaiAppends++;
              // ✅ Only count ms if append was actually sent
              state.openaiBufferedMs += ms;
            } catch {}
          }

          if (state.twilioFrames === 1 || state.twilioFrames % 200 === 0) {
            this.logger.log(
              `Twilio media tenantId=${state.tenantId} frames=${state.twilioFrames} openaiReady=${state.openaiReady} appends=${state.openaiAppends} openaiBufferedMs=${state.openaiBufferedMs}`,
            );
          }
          return;
        }

        if (msg.event === 'stop') {
          this.detach(state.key, 'twilio-stop');
          return;
        }
      } catch (e: any) {
        this.logger.error(`twilio message parse error: ${e?.message || e}`);
      }
    });

    ws.on('close', () => this.detach(state.key, 'twilio-close'));
    ws.on('error', (e) => this.detach(state.key, `twilio-error:${(e as any)?.message || e}`));
  }

  // --------------------------
  // OpenAI realtime
  // --------------------------

  private ensureOpenAI(sessionKey: string) {
    const state = this.sessions.get(sessionKey);
    if (!state || state.closed) return;

    if (!this.apiKey) {
      state.openaiLastError = 'OPENAI_API_KEY missing';
      this.logger.error(`OpenAI key missing. sessionKey=${sessionKey}`);
      return;
    }

    if (
      state.openai &&
      (state.openai.readyState === WebSocket.OPEN || state.openai.readyState === WebSocket.CONNECTING)
    ) {
      return;
    }

    try {
      if (state.openaiReconnectTimer) clearTimeout(state.openaiReconnectTimer);
    } catch {}
    state.openaiReconnectTimer = undefined;

    const ws = new WebSocket(this.openaiUrl, {
      headers: {
        Authorization: `Bearer ${this.apiKey}`,
        'OpenAI-Beta': 'realtime=v1',
      },
    });

    state.openai = ws;
    state.openaiReady = false;
    state.openaiBufferedMs = 0;

    ws.on('open', () => {
      state.openaiReady = true;
      state.openaiReconnectAttempts = 0;
      this.logger.log(`OpenAI WS connected tenantId=${state.tenantId} sessionKey=${sessionKey}`);

      state.openaiPingTimer = setInterval(() => {
        try {
          if (ws.readyState === WebSocket.OPEN) ws.ping();
        } catch {}
      }, this.OPENAI_PING_MS);

      const VOICE = (process.env.OPENAI_REALTIME_VOICE || 'alloy').trim();
      const MODEL = (process.env.OPENAI_REALTIME_MODEL || 'gpt-4o-realtime-preview').trim();
      const TRANSCRIBE_MODEL = (process.env.OPENAI_TRANSCRIBE_MODEL || 'whisper-1').trim();

      const premiumInstructions = [
        'Sen bir güzellik merkezi için premium resepsiyonist asistanısın.',
        'Türkçe konuş.',
        'Doğal, sıcak, akıcı konuş; robot gibi madde madde sayma.',
        'Cevaplar 1-3 kısa cümle olsun.',
        'Asla "bey/hanım" gibi hitaplar kullanma; sadece ismi aynen kullan.',
        'Kullanıcı bir isim söylediyse: ismi HARFİ HARFİNE tekrar et, değiştirme.',
        'Tarih/saat konusunda EMİN DEĞİLSEN asla kesin konuşma; netleştirmek için 1 kısa soru sor.',
        'Randevu akışında sadece gerekli bilgiyi sor.',
        'Kullanıcı randevudan farklı bir şey sorarsa kısa cevap ver, sonra nazikçe randevuya dön.',
        'Asla teknik terim kullanma.',
        'Sakin tempo, hızlı konuşma.',
      ].join(' ');

      const sessionUpdate = {
        type: 'session.update',
        session: {
          model: MODEL,
          modalities: ['audio', 'text'],
          input_audio_format: 'g711_ulaw',
          output_audio_format: 'g711_ulaw',
          voice: VOICE,

          input_audio_transcription: {
            model: TRANSCRIBE_MODEL,
          },

          // ✅ VAD (latency düşür)
          turn_detection: {
            type: 'server_vad',
            prefix_padding_ms: 200,
            silence_duration_ms: 420,
            create_response: false, // we trigger manually
            interrupt_response: true,
          },

          instructions: premiumInstructions,
        },
      };

      this.logger.log(
        `[RealtimeBridgeService] session.update tenantId=${state.tenantId} model=${MODEL} voice=${VOICE} transcribe=${TRANSCRIBE_MODEL}`,
      );
      ws.send(JSON.stringify(sessionUpdate));

      if (!state.greeted) {
        state.greeted = true;

        ws.send(
          JSON.stringify({
            type: 'response.create',
            response: {
              modalities: ['audio', 'text'],
              instructions: '1 kısa cümle: "Merhaba, hoş geldiniz. Size nasıl yardımcı olabilirim?"',
            },
          }),
        );

        state.responseInProgress = true;
        state.aiHasActiveResponse = true;
        state.lastResponseCreateAt = Date.now();
        this.logger.log(`response.create (greeting) tenantId=${state.tenantId}`);
      }
    });

    ws.on('message', (raw) => {
      let msg: any;
      try {
        msg = JSON.parse(String(raw));
      } catch {
        return;
      }

      const t = msg?.type;
      const s = this.sessions.get(sessionKey);
      if (!s || s.closed) return;

      if (
        t === 'error' ||
        t === 'session.updated' ||
        t === 'response.created' ||
        t === 'response.done' ||
        t === 'input_audio_buffer.speech_started' ||
        t === 'input_audio_buffer.speech_stopped' ||
        t === 'conversation.item.input_audio_transcription.completed'
      ) {
        this.logger.log(`OpenAI event tenantId=${s.tenantId} type=${t}`);
      }

      if (t === 'error') {
        const em = msg?.error?.message || JSON.stringify(msg);
        this.logger.error(`OpenAI error tenantId=${s.tenantId}: ${em}`);
        s.openaiLastError = em;

        // ✅ Buffer küçük hatası gelirse panikleme: sadece local state resetle
        // (agresif clear -> 0ms commit loop yapabiliyor)
        if (String(em).toLowerCase().includes('buffer too small')) {
          s.openaiBufferedMs = 0;
          s.responseInProgress = false;
          s.aiSpeaking = false;
          s.aiHasActiveResponse = false;
          return;
        }

        // other errors: clear safely
        try {
          s.openai?.send(JSON.stringify({ type: 'input_audio_buffer.clear' }));
        } catch {}
        s.openaiBufferedMs = 0;
        s.responseInProgress = false;
        s.aiSpeaking = false;
        s.aiHasActiveResponse = false;
        return;
      }

      if (t === 'conversation.item.input_audio_transcription.completed') {
        const text =
          msg?.transcript ||
          msg?.item?.content?.[0]?.transcript ||
          msg?.content?.[0]?.transcript ||
          '';

        if (text && typeof text === 'string') {
          s.lastUserTranscript = text;
          this.logger.log(`[USER_TRANSCRIPT] tenantId=${s.tenantId} text="${text}"`);
        }
        return;
      }

      if (t === 'response.created') {
        s.responseInProgress = true;
        s.aiHasActiveResponse = true;
        return;
      }

      // --------------------------
      // BARGE-IN
      // --------------------------
      if (t === 'input_audio_buffer.speech_started') {
        const now = Date.now();
        s.lastBargeInAt = now;

        this.logger.log(
          `[BARGE-IN] speech_started tenantId=${s.tenantId} aiSpeaking=${s.aiSpeaking} active=${s.aiHasActiveResponse}`,
        );

        s.dropAudioUntil = now + this.DROP_AUDIO_AFTER_CANCEL_MS;

        // cancel only if we think there is an active response
        if (s.aiHasActiveResponse) {
          try {
            s.openai?.send(JSON.stringify({ type: 'response.cancel' }));
          } catch {}
        }

        // clear input buffer
        try {
          s.openai?.send(JSON.stringify({ type: 'input_audio_buffer.clear' }));
        } catch {}

        // clear Twilio queued audio
        if (s.twilio && s.streamSid) {
          try {
            s.twilio.send(JSON.stringify({ event: 'clear', streamSid: s.streamSid }));
          } catch {}
        }

        // reset local flags
        s.openaiBufferedMs = 0;
        s.aiSpeaking = false;
        s.responseInProgress = false;
        s.aiHasActiveResponse = false;
        return;
      }

      // user stopped speaking -> commit + response.create (only if OpenAI buffer has enough ms)
      if (t === 'input_audio_buffer.speech_stopped') {
        if (!s.openai || !s.openaiReady) return;

        if (s.responseInProgress) {
          this.logger.log(`response.create skipped (already in progress) tenantId=${s.tenantId}`);
          return;
        }

        const now = Date.now();
        if (now - s.lastResponseCreateAt < this.RESPONSE_CREATE_DEBOUNCE_MS) return;

        const ms = s.openaiBufferedMs || 0;
        if (ms < this.MIN_OPENAI_BUFFER_MS) {
          this.logger.warn(
            `[RealtimeBridgeService] skip commit+response.create (OpenAI buffer too short) ms=${ms} tenantId=${s.tenantId}`,
          );
          // clear to avoid growing trash
          try {
            s.openai.send(JSON.stringify({ type: 'input_audio_buffer.clear' }));
          } catch {}
          s.openaiBufferedMs = 0;
          return;
        }

        // commit then create response
        try {
          s.openai.send(JSON.stringify({ type: 'input_audio_buffer.commit' }));
        } catch {}

        s.openaiBufferedMs = 0;
        s.responseInProgress = true;
        s.aiHasActiveResponse = true;
        s.lastResponseCreateAt = now;

        try {
          s.openai.send(JSON.stringify({ type: 'response.create' }));
        } catch {}

        this.logger.log(`response.create tenantId=${s.tenantId} (commitMs=${ms})`);
        return;
      }

      if (
        t === 'response.done' ||
        t === 'response.audio.done' ||
        t === 'response.output_audio.done' ||
        t === 'response.end'
      ) {
        s.aiSpeaking = false;
        s.responseInProgress = false;
        s.aiHasActiveResponse = false;
        return;
      }

      if (t === 'response.audio.delta' || t === 'response.output_audio.delta') {
        const delta = msg?.delta;
        const now = Date.now();
        if (now < (s.dropAudioUntil || 0)) return;

        s.aiHasActiveResponse = true;
        s.aiSpeaking = true;

        if (typeof delta === 'string' && s.twilio && s.streamSid) {
          s.openaiDeltas++;
          try {
            s.twilio.send(
              JSON.stringify({
                event: 'media',
                streamSid: s.streamSid,
                media: { payload: delta },
              }),
            );
          } catch {}

          if (s.openaiDeltas === 1 || s.openaiDeltas % 50 === 0) {
            this.logger.log(
              `OpenAI audio.delta tenantId=${s.tenantId} deltas=${s.openaiDeltas} twilioFrames=${s.twilioFrames}`,
            );
          }
        }
        return;
      }
    });

    ws.on('close', () => this.onOpenAIDown(sessionKey, 'openai-close'));
    ws.on('error', (e) => this.onOpenAIDown(sessionKey, `openai-error:${(e as any)?.message || e}`));
  }

  private onOpenAIDown(sessionKey: string, reason: string) {
    const s = this.sessions.get(sessionKey);
    if (!s || s.closed) return;

    s.openaiReady = false;
    s.openaiLastDisconnectAt = Date.now();

    try {
      if (s.openaiPingTimer) clearInterval(s.openaiPingTimer);
    } catch {}
    s.openaiPingTimer = undefined;

    try {
      s.openai?.close();
    } catch {}
    s.openai = undefined;

    s.openaiBufferedMs = 0;
    s.aiSpeaking = false;
    s.responseInProgress = false;
    s.aiHasActiveResponse = false;
    s.dropAudioUntil = Date.now() + this.DROP_AUDIO_AFTER_CANCEL_MS;

    if (!s.twilio || s.twilio.readyState !== WebSocket.OPEN) {
      this.detach(sessionKey, `openai-down:${reason}-twilio-not-open`);
      return;
    }

    s.openaiReconnectAttempts++;
    const attempt = s.openaiReconnectAttempts;

    if (attempt > this.OPENAI_RECONNECT_MAX) {
      this.logger.error(
        `[RealtimeBridgeService] OpenAI reconnect exceeded max. tenantId=${s.tenantId} attempts=${attempt} -> detach`,
      );
      this.detach(sessionKey, `openai-reconnect-max:${reason}`);
      return;
    }

    const backoff = Math.min(
      this.OPENAI_RECONNECT_MAX_MS,
      this.OPENAI_RECONNECT_BASE_MS * Math.pow(2, attempt - 1),
    );

    this.logger.warn(
      `[RealtimeBridgeService] OpenAI down (${reason}). tenantId=${s.tenantId} reconnect attempt=${attempt} in ${backoff}ms`,
    );

    try {
      if (s.openaiReconnectTimer) clearTimeout(s.openaiReconnectTimer);
    } catch {}

    s.openaiReconnectTimer = setTimeout(() => {
      const latest = this.sessions.get(sessionKey);
      if (!latest || latest.closed) return;
      this.ensureOpenAI(sessionKey);
    }, backoff);
  }

  private detach(sessionKey: string, reason: string) {
    const state = this.sessions.get(sessionKey);
    if (!state || state.closed) return;

    state.closed = true;

    this.logger.warn(
      `Bridge close tenantId=${state.tenantId} sessionKey=${sessionKey} reason=${reason} twilioFrames=${state.twilioFrames} openaiAppends=${state.openaiAppends} openaiDeltas=${state.openaiDeltas} openaiErr=${state.openaiLastError || '-'}`,
    );

    try {
      if (state.keepaliveTimer) clearInterval(state.keepaliveTimer);
    } catch {}
    try {
      if (state.openaiPingTimer) clearInterval(state.openaiPingTimer);
    } catch {}
    try {
      if (state.openaiReconnectTimer) clearTimeout(state.openaiReconnectTimer);
    } catch {}

    try {
      state.openai?.close();
    } catch {}
    try {
      state.twilio?.close();
    } catch {}

    this.sessions.delete(sessionKey);
  }

  private getQueryParam(url: string, key: string): string | null {
    const idx = url.indexOf('?');
    if (idx === -1) return null;
    const qs = url.slice(idx + 1);
    for (const part of qs.split('&')) {
      const [k, v] = part.split('=');
      if (k === key) return decodeURIComponent(v || '');
    }
    return null;
  }
}
