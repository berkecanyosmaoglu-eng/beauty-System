import { Injectable, Logger } from '@nestjs/common';
import { PrismaService } from '../prisma/prisma.service';

type Incoming = {
  tenantId: string;
  from: string;
  to: string;
  text: string;
  raw: any;
  contentType: string;
};

type FlowStep =
  | 'START'
  | 'ASK_NAME'
  | 'ASK_SERVICE'
  | 'ASK_STAFF'
  | 'ASK_DATE'
  | 'ASK_TIME'
  | 'CONFIRM';

type FlowState = {
  step: FlowStep;
  name?: string;
  serviceId?: string;
  staffId?: string;
  date?: string; // YYYY-MM-DD
  time?: string; // HH:mm
};

@Injectable()
export class WhatsappService {
  private readonly logger = new Logger(WhatsappService.name);

  constructor(private readonly prisma: PrismaService) {}

  // --- TWILIO RESPONSE ---
  toTwimlMessage(text: string) {
    return `<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Message>${this.escapeXml(text)}</Message>
</Response>`;
  }

  private escapeXml(s: string) {
    return (s || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&apos;');
  }

  private normalizeWa(v: any): string {
    const s = String(v || '').trim();
    return s.replace(/^whatsapp:/i, '').trim();
  }

  private replyTextOnly(replyText: string) {
    return String(replyText || '').trim() || 'Tamamdır.';
  }

  // -------------------------
  // Delegates (Prisma keys sende net: call_sessions, customers, services, staff, appointments)
  // -------------------------
  private callSessionDelegate(): any {
    const p: any = this.prisma as any;
    return p.call_sessions;
  }
  private dbService(): any {
    const p: any = this.prisma as any;
    return p.services;
  }
  private dbStaff(): any {
    const p: any = this.prisma as any;
    return p.staff;
  }
  private dbCustomer(): any {
    const p: any = this.prisma as any;
    return p.customers;
  }
  private dbAppointment(): any {
    const p: any = this.prisma as any;
    return p.appointments;
  }

  // -------------------------
  // Helpers
  // -------------------------
  private rand(n = 6) {
    return Math.random().toString(36).slice(2, 2 + n);
  }

  private makeId(prefix: string) {
    return `${prefix}_${Date.now()}_${this.rand(6)}`;
  }

  private pickSafeState(v: any): FlowState {
    const step = (v?.step as FlowStep) || 'START';
    return {
      step,
      name: typeof v?.name === 'string' ? v.name : undefined,
      serviceId: typeof v?.serviceId === 'string' ? v.serviceId : undefined,
      staffId: typeof v?.staffId === 'string' ? v.staffId : undefined,
      date: typeof v?.date === 'string' ? v.date : undefined,
      time: typeof v?.time === 'string' ? v.time : undefined,
    };
  }

  // -------------------------
  // Session persistence (call_sessions)
  // Key: tenantId + from
  // State json: context alanına yazıyoruz
  // NOTE: call_sessions.updatedAt zorunlu olabiliyor -> create/update'de set ediyoruz
  // -------------------------
  private async upsertSession(tenantId: string, from: string, to: string) {
    const del = this.callSessionDelegate();
    if (!del?.findFirst || !del?.create) {
      throw new Error('Prisma call_sessions delegate not found.');
    }

    const existing = await del.findFirst({
      where: { tenantId, from },
    });

    if (existing) return existing;

    const now = new Date();
    const callSid = `wa:${tenantId}:${from}:${to || ''}`.slice(0, 255);
    const context: FlowState = { step: 'START' };

    // create minimal + timestamps
    return del.create({
      data: {
        id: this.makeId('wa'),
        tenantId,
        from,
        to: to || null,
        callSid,
        status: 'WA',
        duration: null,
        transcript: null,
        context: context as any,
        customerId: null,
        createdAt: now,
        updatedAt: now,
      } as any,
    });
  }

  private async getSession(id: string) {
    const del = this.callSessionDelegate();
    if (!del?.findUnique) throw new Error('call_sessions missing findUnique');
    return del.findUnique({ where: { id } });
  }

  private async updateSession(id: string, patch: Partial<FlowState>) {
    const del = this.callSessionDelegate();
    if (!del?.findUnique || !del?.update) throw new Error('call_sessions missing update');

    const s = await del.findUnique({ where: { id } });
    const current = this.pickSafeState(s?.context || { step: 'START' });
    const next: FlowState = { ...current, ...patch };

    await del.update({
      where: { id },
      data: { context: next as any, updatedAt: new Date() } as any,
    });
  }

  // -------------------------
  // Customers (SENİN ŞEMAN):
  // customers: id, tenantId, phoneNumber, name, email, notes, createdAt, updatedAt
  // unique: tenantId + phoneNumber
  // -------------------------
  private async findCustomerByPhone(tenantId: string, phone: string): Promise<{ id: string } | null> {
    const custDel = this.dbCustomer();
    if (!custDel?.findFirst) return null;

    return custDel.findFirst({
      where: { tenantId, phoneNumber: phone },
      select: { id: true },
    });
  }

  private async createCustomer(tenantId: string, name: string, phone: string): Promise<{ id: string } | null> {
    const custDel = this.dbCustomer();
    if (!custDel?.create) return null;

    // createdAt/updatedAt DB'de default CURRENT_TIMESTAMP var, ama güvenli olsun diye set edelim
    const now = new Date();
    return custDel.create({
      data: {
        id: this.makeId('cus'),
        tenantId,
        phoneNumber: phone,
        name: name.slice(0, 80),
        email: null,
        notes: null,
        createdAt: now,
        updatedAt: now,
      } as any,
      select: { id: true },
    });
  }

  // -------------------------
  // Appointments (SENİN ŞEMAN):
  // appointments: id, tenantId, customerId, serviceId, staffId, date(timestamp), time(text), endTime(text),
  // status(AppointmentStatus default PENDING), notes(text), channel(SessionChannel), messageSessionId(text), callSessionId(text)
  // createdAt/updatedAt default CURRENT_TIMESTAMP
  // -------------------------
  private addMinutesToHHmm(hhmm: string, minutes: number): string {
    const [hh, mm] = hhmm.split(':').map((x) => Number(x));
    const base = hh * 60 + mm;
    const next = base + minutes;
    const nh = Math.floor(next / 60) % 24;
    const nm = next % 60;
    return `${String(nh).padStart(2, '0')}:${String(nm).padStart(2, '0')}`;
  }

  private buildStartDateTime(dateISO: string, timeHHmm: string): Date | null {
    const d = new Date(`${dateISO}T${timeHHmm}:00`);
    if (Number.isNaN(d.getTime())) return null;
    return d;
  }

  // --- MAIN FLOW ---
  async handleIncoming(input: Incoming): Promise<string> {
    const tenantId = String(input.tenantId || '').trim();
    const from = this.normalizeWa(input.from);
    const to = this.normalizeWa(input.to);
    const text = String(input.text || '').trim();
    const lower = text.toLowerCase();

    if (!tenantId) {
      return this.replyTextOnly('Merhaba! (tenant bulunamadı) Test için webhook’a tenantId gönderelim.');
    }
    if (!from || !text) {
      return this.replyTextOnly('Mesajınızı göremedim. Lütfen tekrar yazar mısınız?');
    }

    this.logger.log(`📩 WA inbound tenantId=${tenantId} from=${from} text="${text.slice(0, 200)}"`);

    const session = await this.upsertSession(tenantId, from, to);
    const state = this.pickSafeState(session?.context || { step: 'START' });

    // cancel
    if (/(iptal|vazgeç|cancel|boşver)/i.test(lower)) {
      await this.updateSession(session.id, { step: 'START' });
      return this.replyTextOnly('Tamamdır. İstersen tekrar yaz, randevu için yardımcı olurum.');
    }

    switch (state.step) {
      case 'START': {
        await this.updateSession(session.id, { step: 'ASK_NAME' });
        return this.replyTextOnly('Merhaba! Randevu için adınızı yazar mısınız?');
      }

      case 'ASK_NAME': {
        await this.updateSession(session.id, { step: 'ASK_SERVICE', name: text.slice(0, 60) });
        return this.replyTextOnly('Hangi hizmeti almak istiyorsunuz? (ör: lazer, cilt, tırnak)');
      }

      case 'ASK_SERVICE': {
        const svcDel = this.dbService();
        if (!svcDel?.findFirst) {
          return this.replyTextOnly('Hizmet tablosu bulunamadı (services).');
        }

        const service = await svcDel.findFirst({
          where: { tenantId, name: { contains: text, mode: 'insensitive' } },
          select: { id: true, name: true, duration: true },
        });

        if (!service) {
          return this.replyTextOnly('Bu hizmeti bulamadım. Daha kısa yazar mısın? (ör: lazer)');
        }

        await this.updateSession(session.id, { step: 'ASK_STAFF', serviceId: service.id });
        return this.replyTextOnly('Hangi personel/usta olsun? (bilmiyorsan "fark etmez" yaz)');
      }

      case 'ASK_STAFF': {
        const staffDel = this.dbStaff();
        if (!staffDel?.findFirst) {
          return this.replyTextOnly('Staff tablosu bulunamadı. (staff)');
        }

        let staff: { id: string } | null = null;

        // "fark etmez" => ilk aktif personeli seç
        if (/fark etmez|farketmez|bilmiyorum|sen seç/i.test(lower)) {
          staff = await staffDel.findFirst({
            where: { tenantId, isActive: true },
            select: { id: true },
            orderBy: { createdAt: 'asc' },
          });
        } else {
          staff = await staffDel.findFirst({
            where: { tenantId, name: { contains: text, mode: 'insensitive' } },
            select: { id: true },
          });
          if (!staff) {
            // yine de fallback: ilk aktif
            staff = await staffDel.findFirst({
              where: { tenantId, isActive: true },
              select: { id: true },
              orderBy: { createdAt: 'asc' },
            });
          }
        }

        if (!staff) {
          return this.replyTextOnly('Personel bulunamadı. Önce staff ekleyelim.');
        }

        await this.updateSession(session.id, { step: 'ASK_DATE', staffId: staff.id });
        return this.replyTextOnly('Hangi gün istiyorsunuz? (YYYY-AA-GG ör: 2026-02-07) veya "yarın"');
      }

      case 'ASK_DATE': {
        const date = this.parseDateToISO(text);
        if (!date) {
          return this.replyTextOnly('Tarihi anlayamadım. Örnek: 2026-02-07 ya da "yarın"');
        }

        await this.updateSession(session.id, { step: 'ASK_TIME', date });
        return this.replyTextOnly('Saat kaç olsun? (HH:mm ör: 15:30)');
      }

      case 'ASK_TIME': {
        const time = this.parseTime(text);
        if (!time) {
          return this.replyTextOnly('Saati anlayamadım. Örnek: 15:30');
        }

        await this.updateSession(session.id, { step: 'CONFIRM', time });

        const s2 = await this.getSession(session.id);
        const date = String(((s2?.context as any)?.date ?? '')).trim();
        const requestedLabel = `${date} ${time}`.trim();

        return this.replyTextOnly(`Özet: ${requestedLabel} için randevu oluşturalım mı? (evet/hayır)`);
      }

      case 'CONFIRM': {
        if (!/(evet|ok|tamam|onay)/i.test(lower)) {
          await this.updateSession(session.id, { step: 'ASK_TIME' });
          return this.replyTextOnly('Tamam. O zaman farklı bir saat yaz (HH:mm).');
        }

        const s3 = await this.getSession(session.id);
        const st = this.pickSafeState(s3?.context || {});

        if (!st.date || !st.time || !st.serviceId || !st.name || !st.staffId) {
          await this.updateSession(session.id, { step: 'START' });
          return this.replyTextOnly('Bir şey karıştı 🙈 Baştan alalım: adınızı yazar mısınız?');
        }

        try {
          const svcDel = this.dbService();
          const apptDel = this.dbAppointment();

          if (!svcDel?.findUnique) return this.replyTextOnly('Hizmet tablosuna erişemedim.');
          if (!apptDel?.create) return this.replyTextOnly('Randevu tablosuna erişemedim.');

          const service = await svcDel.findUnique({
            where: { id: st.serviceId },
            select: { duration: true, name: true },
          });

          if (!service) {
            await this.updateSession(session.id, { step: 'START' });
            return this.replyTextOnly('Hizmet bulunamadı. Baştan alalım.');
          }

          // customer find/create
          let customer = await this.findCustomerByPhone(tenantId, from);
          if (!customer) {
            customer = await this.createCustomer(tenantId, st.name, from);
          }
          if (!customer?.id) {
            await this.updateSession(session.id, { step: 'START' });
            return this.replyTextOnly('Müşteri kaydı oluşturamadım. (customers: phoneNumber/name)');
          }

          const startAt = this.buildStartDateTime(st.date, st.time);
          if (!startAt) {
            await this.updateSession(session.id, { step: 'ASK_DATE' });
            return this.replyTextOnly('Tarih/saat formatı hatalı. Tarihi tekrar yazar mısın?');
          }

          const durationMin = Number((service as any).duration || 30);
          const endTime = this.addMinutesToHHmm(st.time, durationMin);

          const baseData: any = {
            id: this.makeId('apt'),
            tenantId,
            customerId: customer.id,
            serviceId: st.serviceId,
            staffId: st.staffId,
            date: startAt,         // timestamp
            time: st.time,         // text
            endTime,               // text
createdAt: new Date(),
updatedAt: new Date(),          
  notes: null,
            messageSessionId: null,
            callSessionId: session.id, // call_sessions FK var sende
          };

          // channel/status enum olabilir => önce dene, patlarsa plain create
          try {
            await apptDel.create({
              data: {
                ...baseData,
                channel: 'WHATSAPP',
                status: 'PENDING',
              } as any,
            });
          } catch {
            await apptDel.create({ data: baseData });
          }

          await this.updateSession(session.id, { step: 'START' });

          return this.replyTextOnly(
            `✅ Randevu oluşturuldu: ${st.date} ${st.time} (${(service as any).name || 'hizmet'})`,
          );
        } catch (e: any) {
          this.logger.warn(`appointment.create failed: ${String(e?.message || e)}`);
          await this.updateSession(session.id, { step: 'START' });
          return this.replyTextOnly('Randevu kaydı şu an oluşturulamadı. Tekrar dener misiniz?');
        }
      }
    }
  }

  // -------------------------
  // Parsing
  // -------------------------
  private parseDateToISO(input: string): string | null {
    const s = input.trim().toLowerCase();
    const now = new Date();

    if (s === 'yarın' || s === 'yarin') {
      const d = new Date(now);
      d.setDate(d.getDate() + 1);
      return d.toISOString().slice(0, 10);
    }

    if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;
    return null;
  }

  private parseTime(input: string): string | null {
    const s = input.trim();
    if (/^\d{1,2}:\d{2}$/.test(s)) {
      const [hh, mm] = s.split(':').map(Number);
      if (hh >= 0 && hh <= 23 && mm >= 0 && mm <= 59) {
        return `${String(hh).padStart(2, '0')}:${String(mm).padStart(2, '0')}`;
      }
    }
    return null;
  }
}
