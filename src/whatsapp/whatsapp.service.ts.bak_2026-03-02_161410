import { Injectable, Logger } from '@nestjs/common';
import { AgentService } from '../agent/agent.service';
import { PrismaService } from '../prisma/prisma.service';

type Incoming = {
  tenantId: string;
  from: string;
  to: string;
  text: string;
  raw: any;
  contentType: string;
};

@Injectable()
export class WhatsappService {
  private readonly logger = new Logger(WhatsappService.name);

  // prisma/schema.prisma enum NotificationType: WHATSAPP | SMS | EMAIL
  private readonly NOTIF_TYPE: 'WHATSAPP' = 'WHATSAPP';

  constructor(
    private readonly agent: AgentService,
    private readonly prisma: PrismaService,
  ) {}

  // --- TWILIO RESPONSE (Webhook reply için) ---
  toTwimlMessage(text: string) {
    return `<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Message>${this.escapeXml(text)}</Message>
</Response>`;
  }

  private escapeXml(s: string) {
    return (s || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&apos;');
  }

  private normalizeWa(v: any): string {
    const s = String(v || '').trim();
    return s.replace(/^whatsapp:/i, '').trim();
  }

  private replyTextOnly(replyText: string) {
    return String(replyText || '').trim() || 'Tamamdır.';
  }

  async handleIncoming(input: Incoming): Promise<string> {
    const tenantId = String(input.tenantId || '').trim();
    const from = this.normalizeWa(input.from);
    const to = this.normalizeWa(input.to);
    const text = String(input.text || '').trim();

    if (!tenantId)
      return this.replyTextOnly('Merhaba! (tenant bulunamadı) webhook’a tenantId gönderelim.');
    if (!from || !text) return this.replyTextOnly('Mesajını göremedim. Tekrar yazar mısın?');

    this.logger.log(
      `📩 WA inbound tenantId=${tenantId} from=${from} to=${to} text="${text.slice(0, 200)}"`,
    );

    try {
      // AgentService senin ana beyin
      const reply = await this.agent.replyText({ tenantId, from, text });
      return this.replyTextOnly(reply);
    } catch (e: any) {
      this.logger.error(`Agent replyText failed: ${e?.message || e}`);
      return this.replyTextOnly('Şu an bir hata oluştu 😕 Lütfen tekrar dener misin?');
    }
  }

  // --- PROACTIVE SEND (cron / reminder / sistem mesajı) ---
  private async getTwilioClient() {
    const sid = process.env.TWILIO_ACCOUNT_SID || process.env.TWILIO_SID;
    const token = process.env.TWILIO_AUTH_TOKEN || process.env.TWILIO_TOKEN;
    if (!sid || !token) throw new Error('TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN missing');

    // twilio paketi yoksa runtime’da anlaşılır hata versin
    // eslint-disable-next-line @typescript-eslint/no-var-requires
    const twilio = require('twilio');
    return twilio(sid, token);
  }

  private normalizeToWhatsapp(toPhoneRaw: string) {
    const p = String(toPhoneRaw || '').trim();
    if (!p) return '';
    if (/^whatsapp:/i.test(p)) return p; // whatsapp:+...
    if (p.startsWith('+')) return `whatsapp:${p}`; // +90...
    if (p.startsWith('90')) return `whatsapp:+${p}`; // 90...
    if (p.startsWith('0')) return `whatsapp:+9${p}`; // 0...
    return `whatsapp:+90${p}`; // default TR
  }

  private getWhatsappFrom(): string {
    const from =
      process.env.TWILIO_WHATSAPP_FROM ||
      process.env.WHATSAPP_FROM ||
      process.env.TWILIO_FROM_WHATSAPP ||
      '';
    if (!from) throw new Error('TWILIO_WHATSAPP_FROM (or WHATSAPP_FROM) missing');
    return this.normalizeToWhatsapp(from);
  }

  /**
   * Proaktif WhatsApp (cron/hatırlatma).
   * NOT: Analytics/log için mevcut "notifications" tablosuna yazıyoruz.
   */
  async sendProactiveWhatsApp(params: {
    tenantId: string;
    toPhone: string;
    body: string;
    appointmentId?: string;
    subject?: string;
    metadata?: any;
  }) {
    const tenantId = String(params.tenantId || '').trim();
    if (!tenantId) throw new Error('tenantId empty');

    const to = this.normalizeToWhatsapp(params.toPhone);
    if (!to) throw new Error('toPhone empty');

    const body = String(params.body || '').trim();
    if (!body) throw new Error('body empty');

    const subject = params.subject || 'WhatsApp';
    const from = this.getWhatsappFrom();

    // 1) önce notification kaydı aç (pending)
    const notif = await this.prisma.notifications.create({
      data: {
        tenantId,
        type: this.NOTIF_TYPE,
        recipient: to.replace(/^whatsapp:/i, ''), // db’de whatsapp: prefix olmasın diye
        subject,
        body,
        status: 'pending',
        metadata: {
          direction: 'outbound',
          channel: 'whatsapp',
          appointmentId: params.appointmentId || null,
          to,
          from,
          ...((params.metadata || {}) as any),
        },
      } as any,
      select: { id: true },
    });

    // 2) Twilio gönder
    try {
      const client = await this.getTwilioClient();
      const res = await client.messages.create({
        from,
        to,
        body,
      });

      // 3) sent update
      await this.prisma.notifications.update({
        where: { id: notif.id },
        data: {
          status: 'sent',
          sentAt: new Date(),
          metadata: {
            direction: 'outbound',
            channel: 'whatsapp',
            appointmentId: params.appointmentId || null,
            to,
            from,
            provider: 'twilio',
            providerMessageId: String(res?.sid || ''),
            ...((params.metadata || {}) as any),
          },
        } as any,
      });

      return res;
    } catch (e: any) {
      this.logger.error(`sendProactiveWhatsApp failed: ${e?.message || e}`);

      // failed update (cron’u kırmayalım)
      try {
        await this.prisma.notifications.update({
          where: { id: notif.id },
          data: {
            status: 'failed',
            metadata: {
              direction: 'outbound',
              channel: 'whatsapp',
              appointmentId: params.appointmentId || null,
              to,
              from,
              error: String(e?.message || e),
              ...((params.metadata || {}) as any),
            },
          } as any,
        });
      } catch (e2: any) {
        this.logger.warn(`notifications update failed: ${e2?.message || e2}`);
      }

      throw e;
    }
  }
}
