import { Injectable, Logger } from '@nestjs/common';
import OpenAI from 'openai';
import { PrismaService } from '../prisma/prisma.service';

type BookingDraft = {
  tenantId: string;
  customerPhone: string;
  customerName?: string | null;

  serviceId?: string;
  staffId?: string;

  // ISO string (+03:00)
  startAt?: string;
};

enum WaState {
  IDLE = 'IDLE',
  WAIT_SERVICE = 'WAIT_SERVICE',
  WAIT_STAFF = 'WAIT_STAFF',
  WAIT_NAME = 'WAIT_NAME',
  WAIT_DATETIME = 'WAIT_DATETIME',
  WAIT_CONFIRM = 'WAIT_CONFIRM',
}

type HistoryTurn = {
  role: 'user' | 'assistant';
  text: string;
  ts: number;
};

type SuggestionItem = {
  id?: string; // staffId gibi
  label: string; // kullanıcıya gösterilen
  value: string; // staffId ya da startAt ISO
};

type Suggestions = {
  type: 'staff' | 'slot';
  items: SuggestionItem[];
  ts: number;
};

type LearningProfile = {
  // müşterinin geçmiş tercihleri (best-effort)
  preferredServiceId?: string | null;
  preferredStaffId?: string | null;
  preferredTimeHint?: string | null; // örn "17:00" (HH:MM)
  lastServiceId?: string | null;
  lastStaffId?: string | null;
  lastStartAt?: string | null; // ISO +03:00
  updatedAt?: number;
};

type SessionState = {
  state: WaState;
  draft: BookingDraft;

  // ✅ kullanıcı tarih+saat yazdıysa (tam datetime)
  pendingStartAt?: string;

  // ✅ kullanıcı sadece tarih yazdıysa (ör: "yarın", "15.02", "salı")
  pendingDateOnly?: string; // YYYY-MM-DD (TR)

  pendingSummary?: string;

  updatedAt: number;
  history: HistoryTurn[];

  lastAssistantReply?: string;
  lastTopic?: string;
  lastServiceId?: string;
  repeatCount?: number;

  // webhook retry dedup
  lastUserTextNorm?: string;
  lastUserAt?: number;

  // idempotency (10 dk)
  lastCreatedBookingKey?: string;
  lastCreatedAppointmentId?: string;
  lastCreatedAt?: number;

  // ✅ kritik: son öneriler (personel/saat) -> seçim parser buradan çalışır
  lastSuggestions?: Suggestions;

  // ✅ self-learning customer profile (best-effort cache)
  learningProfile?: LearningProfile;
  learningLoadedAt?: number;

  // ✅ öğrenen profil: son önerilen hizmet (evet/hayır ile hızlı seçilsin)
  suggestedServiceId?: string;
  suggestedServiceName?: string;

  // legacy
  lastAssistantText?: string;
};

type LearnedCustomerContext = {
  customerId?: string;
  name?: string | null;
  summary?: string; // LLM'e gidecek kısa özet
  topServiceId?: string;
  topServiceName?: string;
};

@Injectable()
export class AgentService {
  private readonly logger = new Logger(AgentService.name);
  private readonly openai =
    process.env.OPENAI_API_KEY ? new OpenAI({ apiKey: process.env.OPENAI_API_KEY }) : null;

  constructor(private readonly prisma: PrismaService) {}

  private sessions = new Map<string, SessionState>();

  // =========================
  // ✅ “Bot kokusunu” azaltan minik metin motoru (LLM yoksa bile insan gibi)
  // =========================
  private pickOne(list: string[], seedText?: string) {
    if (!list?.length) return '';
    const seed = normalizeTr(seedText || '') || String(Date.now());
    let h = 0;
    for (let i = 0; i < seed.length; i++) h = (h * 31 + seed.charCodeAt(i)) >>> 0;
    return list[h % list.length];
  }

  private softYesNoHint(seed?: string) {
    return this.pickOne(
      [
        'Onaylayalım mı? (E/H)',
        'Tamamlayayım mı? (E/H)',
        'Onaylıyor musunuz? (E/H)',
      ],
      seed,
    );
  }

  private humanizeAsk(kind: 'service' | 'staff' | 'name' | 'datetime', seed?: string) {
    if (kind === 'service') {
      return this.pickOne(
        [
          'Harika 🙂 Hangi işlem için randevu oluşturalım?',
          'Tamam 👍 Hangi hizmeti istersiniz?',
          'Süper. Hangi işlem için yardımcı olayım?',
        ],
        seed,
      );
    }
    if (kind === 'staff') {
      return this.pickOne(
        [
          'Kiminle olsun istersiniz? (İsterseniz “fark etmez” de diyebilirsiniz.)',
          'Hangi personeli tercih edersiniz? (Fark etmez derseniz ben seçeyim.)',
        ],
        seed,
      );
    }
    if (kind === 'name') {
      return this.pickOne(
        [
          'Randevuyu kimin adına yazalım? (Ad soyad)',
          'İsminizi alabilir miyim? (Ad soyad yeterli)',
        ],
        seed,
      );
    }
    return this.pickOne(
      [
        'Hangi gün/saat uygun olur? (08:00-22:00, örn: “yarın 16:00”)',
        'Ne zamana ayarlayalım? (Örn: “Salı 15:30” / “yarın 16:00”)',
        'Gün ve saat alayım 🙂 (08:00-22:00, örn: “yarın 16:00”)',
      ],
      seed,
    );
  }

  private humanizeAskTimeOnly(seed?: string) {
    return this.pickOne(
      [
        'Tamam 👍 Kaça ayarlayalım? (08:00-22:00, örn: “16:00”)',
        'Süper. Saat kaç olsun? (Örn: “16:00”)',
        'Harika 🙂 Saat alayım: (08:00-22:00)',
      ],
      seed,
    );
  }

  private humanizeConfirmNeedEH(seed?: string) {
    return this.pickOne(
      [
        'Son bir onay alayım 🙂 “E” (evet) / “H” (hayır) yazar mısınız?',
        'Onaylıyor muyuz? “E” ya da “H” yazmanız yeterli 🙂',
      ],
      seed,
    );
  }

  private formatBookingSuccess(startAtIso: string, apptId: string, seed?: string) {
    return this.pickOne(
      [
        `Tamamdır ✅ Randevunuzu ayarladım.\n📅 ${prettyIstanbul(startAtIso)}\n🧾 No: ${apptId}`,
        `Süper 🙂 Randevu tamam.\n📅 ${prettyIstanbul(startAtIso)}\n🧾 No: ${apptId}`,
        `Harika ✅ Kaydettim.\n📅 ${prettyIstanbul(startAtIso)}\n🧾 No: ${apptId}`,
      ],
      seed || startAtIso + apptId,
    );
  }

  async replyText(opts: { tenantId: string; from: string; text: string }): Promise<string> {
    const { tenantId, from } = opts;
    const raw = (opts.text ?? '').trim();
    const msg = normalizeTr(raw);

    const key = `${tenantId}:${from}`;
    const session = this.getOrInitSession(key, tenantId, from);

    // ✅ best-effort inbound dedup (webhook retry)
    if (this.isLikelyDuplicateInbound(session, raw)) {
      const prev = session.lastAssistantReply || session.lastAssistantText || 'Tamam 👍';
      return this.safeReply(session, prev);
    }

    // ✅ history
    this.recordHistory(session, 'user', raw);

    try {
      // =========================
      // Global: cancel / restart
      // =========================
      if (isCancel(msg)) {
        this.softResetSession(session, tenantId, from, { keepIdempotency: true });
        this.saveSession(key, session);
        return this.safeReply(session, 'Tamam 👍 İptal ettim. Yeni randevu için “randevu” yazabilirsin.');
      }

      if (isRestart(msg)) {
        this.softResetSession(session, tenantId, from, { keepIdempotency: true });
        session.state = WaState.WAIT_SERVICE;
        this.saveSession(key, session);

        const services = await this.safeListServices(tenantId);
        const reply = this.askService(services, { gentle: true });
        return this.safeReply(session, reply);
      }

      // =========================
      // DB (business/services/staff)
      // =========================
      const business = await (this.prisma as any).businessProfile
        ?.findUnique({ where: { tenantId } })
        .catch(() => null);

      const services = await this.safeListServices(tenantId);
      const staff = await this.safeListStaff(tenantId);

      // =========================
      // ✅ Öğrenen profil (DB'den): müşteri adı + geçmiş özet
      // =========================
      const learned = await this.safeGetLearnedCustomerContext(tenantId, from, services);

      // müşteri adı varsa otomatik doldur (akış bozmasın)
      if (learned?.name && !session.draft.customerName) {
        session.draft.customerName = String(learned.name);
      }

      // =========================
      // Booking flow active?
      // =========================
      if (session.state !== WaState.IDLE) {
        const reply = await this.handleBookingFlow({
          key,
          session,
          tenantId,
          from,
          msg,
          raw,
          services,
          staff,
        });
        this.saveSession(key, session);
        return this.safeReply(session, reply);
      }

      // =========================
      // ✅ Booking intent (IMPROVED)
      // =========================
      if (looksLikeBookingIntent(raw)) {
        // konuşmadan service yakala
        const svc = this.detectServiceFromMessage(raw, services);
        if (svc?.id) session.draft.serviceId = String(svc.id);

        // tarih/saat erken geldiyse yakala (saat yoksa SAAT SORACAĞIZ)
        const parsed = parseDateTimeTR(raw);
        if (parsed?.hasTime) {
          session.pendingStartAt = toIstanbulIso(clampToFuture(parsed.dateUtc));
          if (!session.draft.startAt && session.pendingStartAt) session.draft.startAt = session.pendingStartAt;
          session.pendingDateOnly = undefined;
        } else if (parsed?.dateOnly) {
          session.pendingDateOnly = parsed.dateOnly; // ✅ "salı" da buraya düşer
        }

        // staff da mesajda geçiyorsa yakala (ama "fark etmez" ise yakalama)
        if (!isNoPreferenceStaff(raw)) this.tryAutofillStaff(session.draft, staff, raw);

        // ✅ Öğrenen profil: hizmet yoksa, en sık aldığı hizmeti öner (tek soru)
        if (!session.draft.serviceId && learned?.topServiceId && learned?.topServiceName) {
          session.state = WaState.WAIT_SERVICE;
          session.suggestedServiceId = learned.topServiceId;
          session.suggestedServiceName = learned.topServiceName;
          this.saveSession(key, session);

          const q = this.pickOne(
            [
              `Geçen sefer ${learned.topServiceName} almıştınız. Yine aynı işlem için randevu olsun mu? (E/H)`,
              `En son ${learned.topServiceName} yaptırmıştınız 🙂 Yine onun için randevu ayarlayayım mı? (E/H)`,
            ],
            from + learned.topServiceId,
          );

          return this.safeReply(session, q);
        }

        // state seç
        if (!session.draft.serviceId) {
          session.state = WaState.WAIT_SERVICE;
          this.saveSession(key, session);
          return this.safeReply(session, await this.naturalAsk(session, 'service', { services, staff, business }));
        }

        if (staff && staff.length > 0 && !session.draft.staffId) {
          session.state = WaState.WAIT_STAFF;
          this.saveSession(key, session);

          // ✅ personel tercihi sorusu: NUMARALI + lastSuggestions
          return this.safeReply(session, this.askStaffMenu(session, staff));
        }

        session.state = WaState.WAIT_NAME;
        this.saveSession(key, session);
        return this.safeReply(session, await this.naturalAsk(session, 'name', { services, staff, business }));
      }

      // =========================
      // Price question
      // =========================
      if (looksLikePriceQuestion(msg)) {
        const svc = this.detectServiceFromMessage(raw, services);
        if (svc) {
          const name = String(svc.name || 'Hizmet');
          const price = svc.price ?? null;
          const dur = svc.duration ?? null;

          const parts: string[] = [];
          if (price != null) parts.push(`${name} fiyatı: ${price}₺`);
          else parts.push(`${name} için fiyat bilgisi henüz eklenmemiş görünüyor.`);
          if (dur != null) parts.push(`Süre: ${dur} dk`);

          const nudge = this.shouldNudgeBooking(session) ? '\nİstersen “randevu oluştur” yaz, hemen ayarlayalım.' : '';
          return this.safeReply(session, parts.join(' • ') + nudge);
        }
        return this.safeReply(session, 'Hangi hizmetin fiyatını soruyorsun? (Örn: “Lazer epilasyon fiyatı”)');
      }

      // =========================
      // Service list
      // =========================
      if (looksLikeServiceListRequest(msg)) {
        const list = servicesToTextShort(services);
        if (!list) return this.safeReply(session, 'Şu an hizmet listem görünmüyor 😕 Birazdan tekrar dener misin?');
        return this.safeReply(session, `Hizmetlerimiz:\n${list}`);
      }

      // =========================
      // Address / hours (08:00-22:00)
      // =========================
      if (looksLikeAddressOrHours(msg)) {
        const addr = business?.address || business?.fullAddress || business?.location || null;

        const parts: string[] = [];
        if (addr) parts.push(`📍 Adres: ${String(addr)}`);
        parts.push(`⏰ Çalışma saatleri: Her gün 08:00 - 22:00`);

        return this.safeReply(session, parts.join('\n'));
      }

      // =========================
      // Procedure / process
      // =========================
      if (looksLikeProcedureQuestion(msg)) {
        const svc = this.detectServiceFromMessage(raw, services);
        session.lastTopic = 'procedure';
        session.lastServiceId = svc && svc.id ? String(svc.id) : undefined;

        let out = await this.answerWithLLM({
          raw,
          business,
          services,
          staff,
          history: this.getRecentHistory(session, 8),
          mode: 'procedure',
          focusService: svc ? { name: String(svc.name || ''), duration: svc.duration, price: svc.price } : null,
          learnedCustomerSummary: learned?.summary || '',
        });

        if (!out) {
          const base = svc
            ? this.procedureTemplateForService(String(svc.name || ''), svc.duration, svc.price)
            : 'Genel olarak süreç kişiye göre değişir. Hangi işlem için soruyorsun? (Örn: lazer, kaş, tırnak)';
          return this.safeReply(session, base);
        }

        if (session.lastAssistantReply && normalizeTr(session.lastAssistantReply) === normalizeTr(out)) {
          const alt = await this.answerWithLLM({
            raw,
            business,
            services,
            staff,
            history: this.getRecentHistory(session, 8),
            mode: 'procedure',
            focusService: svc ? { name: String(svc.name || ''), duration: svc.duration, price: svc.price } : null,
            avoidRepeat: true,
            learnedCustomerSummary: learned?.summary || '',
          });
          if (alt && normalizeTr(alt) !== normalizeTr(session.lastAssistantReply || '')) out = alt;
          else out = 'Hangi bölge için düşünüyorsunuz?';
        }

        return this.safeReply(session, out);
      }

      // =========================
      // General: LLM fallback
      // =========================
      session.lastTopic = 'general';
      session.lastServiceId = undefined;

      let llmAnswer = await this.answerWithLLM({
        raw,
        business,
        services,
        staff,
        history: this.getRecentHistory(session, 8),
        mode: 'general',
        focusService: null,
        learnedCustomerSummary: learned?.summary || '',
      });

      if (!llmAnswer) llmAnswer = '';

      if (llmAnswer && session.lastAssistantReply && normalizeTr(session.lastAssistantReply) === normalizeTr(llmAnswer)) {
        const alt = await this.answerWithLLM({
          raw,
          business,
          services,
          staff,
          history: this.getRecentHistory(session, 8),
          mode: 'general',
          focusService: null,
          avoidRepeat: true,
          learnedCustomerSummary: learned?.summary || '',
        });
        llmAnswer =
          alt && normalizeTr(alt) !== normalizeTr(session.lastAssistantReply || '')
            ? alt
            : 'Tam olarak ne öğrenmek istiyorsunuz?';
      }

      return this.safeReply(session, llmAnswer || 'Anlayamadım 😕 İstersen ne yapmak istediğini kısaca yaz.');
    } catch (e: any) {
      this.logger.error(`[AgentService.replyText] ${e?.message || e}`);
      return this.safeReply(session, 'Şu an bir hata oluştu 😕 Lütfen tekrar dener misin?');
    }
  }

  // =========================
  // Booking State Machine
  // =========================
  private async handleBookingFlow(opts: {
    key: string;
    session: SessionState;
    tenantId: string;
    from: string;
    msg: string;
    raw: string;
    services: any[];
    staff: any[];
  }): Promise<string> {
    const { key, session, tenantId, from, msg, raw, services, staff } = opts;

    // ✅ booking akışındayken vazgeçme / konu değiştirme
    if (shouldExitBookingFlow(msg, raw)) {
      this.softResetSession(session, tenantId, from, { keepIdempotency: true });
      this.saveSession(key, session);
      return 'Tamam 👍 Anladım. Nasıl yardımcı olayım?';
    }

    // ✅ her state’de tarih/saat yakala (AMA saat yoksa startAt setleme)
    const parsedEarly = parseDateTimeTR(raw);
    if (parsedEarly?.hasTime) {
      session.pendingStartAt = toIstanbulIso(clampToFuture(parsedEarly.dateUtc));
      if (!session.draft.startAt && session.pendingStartAt) session.draft.startAt = session.pendingStartAt;
      session.pendingDateOnly = undefined;
    } else if (parsedEarly?.dateOnly) {
      session.pendingDateOnly = parsedEarly.dateOnly; // ✅ "salı" dahil
    }

    // Autofill
    this.tryAutofillService(session.draft, services, raw);

    // staff autofill: "fark etmez" ise sakın staff seçme
    if (!isNoPreferenceStaff(raw)) this.tryAutofillStaff(session.draft, staff, raw);

    // ✅ lastSuggestions üzerinden seçim yakala (personel / slot)
    const picked = this.pickFromSuggestions(session, raw);
    if (picked?.type === 'staff' && picked.staffId) {
      session.draft.staffId = picked.staffId;
    }
    if (picked?.type === 'slot' && picked.startAt) {
      session.draft.startAt = picked.startAt;
      session.pendingStartAt = picked.startAt;
      session.pendingDateOnly = undefined;
    }

    // tek seçenek auto
    if (!session.draft.serviceId && services.length === 1 && services[0]?.id) session.draft.serviceId = String(services[0].id);
    if (!session.draft.staffId && staff.length === 1 && staff[0]?.id) session.draft.staffId = String(staff[0].id);

    // WAIT_SERVICE
    if (session.state === WaState.WAIT_SERVICE) {
      // ✅ önerilen hizmete E/H ile hızlı karar
      if (!session.draft.serviceId && session.suggestedServiceId) {
        if (isYes(msg)) {
          session.draft.serviceId = session.suggestedServiceId;
          session.suggestedServiceId = undefined;
          session.suggestedServiceName = undefined;
        } else if (isNo(msg)) {
          session.suggestedServiceId = undefined;
          session.suggestedServiceName = undefined;
          return await this.naturalAsk(session, 'service', { services, staff, business: null });
        }
      }

      if (!session.draft.serviceId) return await this.naturalAsk(session, 'service', { services, staff, business: null });
      session.state = WaState.WAIT_STAFF;
    }

    // WAIT_STAFF
    if (session.state === WaState.WAIT_STAFF) {
      if (!staff || staff.length === 0) {
        session.state = WaState.WAIT_NAME;
      } else {
        // ✅ kullanıcı "fark etmez" dediyse staff sorma, akışa devam et
        if (isNoPreferenceStaff(raw)) {
          session.draft.staffId = undefined;
          session.state = WaState.WAIT_NAME;
        } else if (!session.draft.staffId) {
          // ✅ NUMARALI personel menüsü
          return this.askStaffMenu(session, staff);
        } else {
          session.state = WaState.WAIT_NAME;
        }
      }
    }

    // WAIT_NAME
    if (session.state === WaState.WAIT_NAME) {
      // Eğer kullanıcı burada personel seçimi yaptıysa isim sormaya devam et
      if (!session.draft.customerName) {
        const maybeName = extractName(raw);

        // Eğer yazdığı şey staff adıysa isim sayma
        const looksLikeStaffName = staff?.some(
          (p: any) => normalizePersonName(String(p?.fullName || '')) === normalizePersonName(raw),
        );
        if (!looksLikeStaffName && !session.draft.customerName && maybeName) session.draft.customerName = maybeName;
      }

      if (!session.draft.customerName) return await this.naturalAsk(session, 'name', { services, staff, business: null });
      session.state = WaState.WAIT_DATETIME;
    }

    // WAIT_DATETIME
    if (session.state === WaState.WAIT_DATETIME) {
      let startIso = session.draft.startAt;

      if (!startIso) {
        // 1) Bu mesajda tam datetime var mı?
        const parsed = parseDateTimeTR(raw);

        // ✅ FIX: pendingDateOnly doluysa ve bu mesajda tarih yoksa -> saat sor
        if (!parsed && session.pendingDateOnly) {
          return this.humanizeAskTimeOnly(raw);
        }

        // 2) Sadece tarih geldiyse: SAAT SOR
        if (parsed && !parsed.hasTime && session.pendingDateOnly) {
          return this.humanizeAskTimeOnly(raw);
        }

        // 3) Sadece saat geldiyse ve elimizde pendingDateOnly varsa: birleştir
        const onlyTime = parseTimeBest(normalizeTr(raw));
        if (onlyTime && session.pendingDateOnly) {
          const [yy, mm, dd] = session.pendingDateOnly.split('-').map(Number);
          const dUtc = new Date(Date.UTC(yy, mm - 1, dd, onlyTime.hh - 3, onlyTime.mm, 0, 0));
          const fixed = clampToFuture(dUtc);
          startIso = toIstanbulIso(fixed);
          session.draft.startAt = startIso;
          session.pendingDateOnly = undefined;
        } else if (parsed?.hasTime) {
          const fixed = clampToFuture(parsed.dateUtc);
          startIso = toIstanbulIso(fixed);
          session.draft.startAt = startIso;
          session.pendingDateOnly = undefined;
        } else {
          // ✅ eğer slot suggestion varsa, kullanıcı "17:15" yazdıysa yakala
          const picked2 = this.pickFromSuggestions(session, raw);
          if (picked2?.type === 'slot' && picked2.startAt) {
            startIso = picked2.startAt;
            session.draft.startAt = startIso;
          } else {
            return this.humanizeAsk('datetime', raw);
          }
        }
      }

      // ✅ çalışma saatleri kontrolü (08:00-22:00)
      if (startIso && !isWithinWorkingHoursIso(startIso)) {
        session.draft.startAt = undefined;
        session.pendingStartAt = undefined;

        const suggestions = suggestWorkingHourAlternatives(startIso, 5);
        return this.askSlotMenu(session, suggestions, `Bu saatlerde çalışmıyoruz 😕\n⏰ 08:00 - 22:00\nŞunlar uygun olabilir:`);
      }

      const pre = await this.precheckAndPrepareConfirm({ tenantId, draft: session.draft });
      if (!pre.ok) {
        if (pre.code === 'OUT_OF_HOURS' && pre.suggestions?.length) {
          session.draft.startAt = undefined;
          const isoList = pre.suggestions.map((s) => s.startAt);
          return this.askSlotMenu(session, isoList, `Bu saatlerde çalışmıyoruz 😕 (08:00 - 22:00)\nŞunlar uygun:`);
        }

        if (pre.code === 'SLOT_TAKEN' && pre.suggestions?.length) {
          // ✅ kritik: slot listesini lastSuggestions'e yaz
          const isoList = pre.suggestions.map((s) => s.startAt);
          return this.askSlotMenu(session, isoList, `O saat dolu 😕 Şunlar uygun:`);
        }

        session.draft.startAt = undefined; // tekrar seçsin
        return this.pickOne(
          [
            'Randevu kontrolünde bir sorun oldu 😕 Farklı bir saat dener misin?',
            'Bir şey takıldı 😕 Başka bir saat deneyelim mi?',
          ],
          raw,
        );
      }

      session.pendingSummary = pre.summary!;
      session.state = WaState.WAIT_CONFIRM;

      return `${pre.summary}\n${this.softYesNoHint(from + (session.draft.startAt || ''))}`;
    }

    // WAIT_CONFIRM
    if (session.state === WaState.WAIT_CONFIRM) {
      // yeni tarih yazdıysa geri dön
      const parsed = parseDateTimeTR(raw);
      if (parsed?.hasTime) {
        const iso = toIstanbulIso(clampToFuture(parsed.dateUtc));
        // çalışma saatleri dışında ise hemen uyar + öner
        if (!isWithinWorkingHoursIso(iso)) {
          const suggestions = suggestWorkingHourAlternatives(iso, 5);
          return this.askSlotMenu(session, suggestions, `Bu saatlerde çalışmıyoruz 😕\n⏰ 08:00 - 22:00\nŞunlar uygun olabilir:`);
        }
        session.draft.startAt = iso;
        session.state = WaState.WAIT_DATETIME;
        return this.handleBookingFlow({ ...opts, session });
      } else if (parsed?.dateOnly) {
        session.pendingDateOnly = parsed.dateOnly;
        return this.humanizeAskTimeOnly(raw);
      }

      const yes = isYes(msg);
      const no = isNo(msg);

      if (!yes && !no) return this.humanizeConfirmNeedEH(raw);

      if (no) {
        session.state = WaState.WAIT_DATETIME;
        session.pendingSummary = undefined;
        session.draft.startAt = undefined;
        session.pendingStartAt = undefined;
        session.lastSuggestions = undefined;
        return this.humanizeAsk('datetime', raw);
      }

      // ✅ idempotency: aynı onay tekrar gelirse çift randevu yok
      const bookingKey = this.makeBookingKey(tenantId, from, session.draft);
      if (
        bookingKey &&
        session.lastCreatedBookingKey === bookingKey &&
        session.lastCreatedAppointmentId &&
        session.lastCreatedAt &&
        Date.now() - session.lastCreatedAt < 10 * 60 * 1000
      ) {
        const startAt = session.draft.startAt || new Date().toISOString();
        const apptId = session.lastCreatedAppointmentId;
        this.softResetSession(session, tenantId, from, { keepIdempotency: true });
        this.saveSession(key, session);
        return this.formatBookingSuccess(startAt, apptId, from + startAt);
      }

      const created = await this.createAppointment({ tenantId, draft: session.draft });

      if (!created.ok && created.code === 'NEED_NAME') {
        session.state = WaState.WAIT_NAME;
        return await this.naturalAsk(session, 'name', { services, staff, business: null });
      }

      if (!created.ok) {
        if (created.code === 'OUT_OF_HOURS' && created.suggestions?.length) {
          session.state = WaState.WAIT_DATETIME;
          session.draft.startAt = undefined;
          const isoList = created.suggestions.map((s) => s.startAt);
          return this.askSlotMenu(session, isoList, `Bu saatlerde çalışmıyoruz 😕 (08:00 - 22:00)\nŞunlar uygun:`);
        }

        if (created.code === 'SLOT_TAKEN' && created.suggestions?.length) {
          session.state = WaState.WAIT_DATETIME;
          session.draft.startAt = undefined;
          const isoList = created.suggestions.map((s) => s.startAt);
          return this.askSlotMenu(session, isoList, `O saat dolu 😕 Şunlar uygun:`);
        }

        session.state = WaState.WAIT_DATETIME;
        session.draft.startAt = undefined;
        return this.pickOne(
          [
            'Randevu oluştururken bir şey ters gitti 😕 Başka bir saat dener misin?',
            'Bir hata oldu 😕 Hangi saat uygun, tekrar deneyelim.',
          ],
          raw,
        );
      }

      // ✅ başarı → idempotency bilgilerini tut + booking alanlarını temizle
      session.lastCreatedBookingKey = bookingKey || undefined;
      session.lastCreatedAppointmentId = created.data.appointmentId;

      // ✅ learn preferences from this successful booking
      await this.learnFromSuccessfulBooking(tenantId, from, session.draft);

      this.softResetSession(session, tenantId, from, { keepIdempotency: true });
      this.saveSession(key, session);

      return this.formatBookingSuccess(created.data.startAt, created.data.appointmentId, from + created.data.startAt);
    }

    // fallback
    session.state = WaState.WAIT_SERVICE;
    return await this.naturalAsk(session, 'service', { services, staff, business: null });
  }

  // =========================
  // Menus: STAFF + SLOT
  // =========================
  private askStaffMenu(session: SessionState, staff: any[]) {
    const items = (staff || [])
      .filter(Boolean)
      .slice(0, 9)
      .map((p: any) => ({
        id: String(p.id),
        label: String(p.fullName || 'Personel'),
        value: String(p.id),
      }));

    session.lastSuggestions = { type: 'staff', items, ts: Date.now() };

    const lines = items.map((it, i) => `${i + 1}) ${it.label}`).join('\n');
    const header = this.pickOne(
      ['Tamam 🙂 Kiminle olsun?', 'Süper. Hangi personeli istersiniz?', 'Kiminle randevu olsun?'],
      items.map((x) => x.label).join('|'),
    );

    return `${header}\n${lines}\n\nİstersen “fark etmez” yazabilirsin.`;
  }

  private askSlotMenu(session: SessionState, isoList: string[], header: string) {
    const items = (isoList || [])
      .filter(Boolean)
      .slice(0, 9)
      .map((iso) => ({
        label: prettyIstanbul(iso),
        value: iso,
      }));

    session.lastSuggestions = { type: 'slot', items, ts: Date.now() };

    const lines = items.map((it, i) => `${i + 1}) ${it.label}`).join('\n');
    const tail = this.pickOne(
      ['Birini seç (1-9) ya da saati yaz (örn “17:15”).', '1-9 yazabilirsin ya da saati direkt yaz (örn “17:15”).'],
      lines,
    );

    return `${header}\n${lines}\n\n${tail}`;
  }

  private pickFromSuggestions(
    session: SessionState,
    raw: string,
  ):
    | { type: 'staff'; staffId: string }
    | { type: 'slot'; startAt: string }
    | null {
    const s = session.lastSuggestions;
    if (!s?.items?.length) return null;

    // öneriler 20 dk sonra geçersiz say
    if (Date.now() - (s.ts || 0) > 20 * 60 * 1000) return null;

    const t = normalizeTr(raw);
    if (!t) return null;

    // 1) Numara seçimi (1-9)
    const mNum = t.match(/^\s*([1-9])\s*$/);
    if (mNum) {
      const idx = Number(mNum[1]) - 1;
      const it = s.items[idx];
      if (!it) return null;
      if (s.type === 'staff') return { type: 'staff', staffId: String(it.value) };
      return { type: 'slot', startAt: String(it.value) };
    }

    // 2) Staff: isim yazdıysa normalize edip eşle
    if (s.type === 'staff') {
      const tn = normalizePersonName(raw);
      const hit = s.items.find((it) => normalizePersonName(it.label) === tn);
      if (hit) return { type: 'staff', staffId: String(hit.value) };
    }

    // 3) Slot: kullanıcı "17:15" gibi yazarsa öneriler içinde saat eşle
    if (s.type === 'slot') {
      const tm = parseTimeBest(t);
      if (tm) {
        const hhmm = `${String(tm.hh).padStart(2, '0')}:${String(tm.mm).padStart(2, '0')}`;
        const hit = s.items.find((it) => normalizeTr(it.label).endsWith(hhmm));
        if (hit) return { type: 'slot', startAt: String(hit.value) };
      }
      // kullanıcı direkt "15.02 17:15" yazarsa label içinde tam eşle
      const hit2 = s.items.find((it) => normalizeTr(it.label) === normalizeTr(raw));
      if (hit2) return { type: 'slot', startAt: String(hit2.value) };
    }

    return null;
  }

  // =========================
  // Natural booking prompts (LLM only for phrasing)
  // =========================
  private async naturalAsk(
    session: SessionState,
    slot: 'service' | 'staff' | 'name' | 'datetime',
    ctx: { services: any[]; staff: any[]; business: any },
  ): Promise<string> {
    const fallback = () => {
      if (slot === 'service') return this.humanizeAsk('service');
      if (slot === 'staff') return this.askStaffMenu(session, ctx.staff);
      if (slot === 'name') return this.humanizeAsk('name');
      return this.humanizeAsk('datetime');
    };

    if (!this.openai) return fallback();

    const missingHint =
      slot === 'service'
        ? 'Müşteriden sadece hangi hizmet istediğini sor.'
        : slot === 'staff'
          ? 'Müşteriden hangi personeli tercih ettiğini sor. “Fark etmez” diyebileceğini de söyle.'
          : slot === 'name'
            ? 'Müşteriden ad soyadını sor. Kısa ve doğal sor.'
            : 'Müşteriden gün ve saat bilgisini sor. Örnek format ver ama çok uzun yazma. Saat aralığı 08:00-22:00.';

    const staffNamesShort = staffToTextShort(ctx.staff) || '';

    const sys = `
Sen bir güzellik merkezi WhatsApp asistanısın. Türkçe konuş.
Stil:
- Samimi, kısa, WhatsApp dili.
- Resmi dil yok, gereksiz uzunluk yok.
- Parantez içinde talimat verme (E/H gibi) — sadece doğal bir soru sor.
Kurallar:
- Sadece TEK soru sor. 1 cümle ideal (maks 2 cümle).
- Kullanıcıyı yormadan ilerlet.
- Listeyi boca etme.
`.trim();

    const user = `
Görev: Rezervasyon akışında eksik bilgi var.
Eksik alan: ${slot}
İpucu: ${missingHint}

Mevcut seçimler:
- serviceId: ${session.draft.serviceId || 'YOK'}
- staffId: ${session.draft.staffId || 'YOK'}
- name: ${session.draft.customerName || 'YOK'}
- startAt: ${session.draft.startAt || 'YOK'}

Personeller (kısa, sadece referans):
${staffNamesShort || 'YOK'}
`.trim();

    try {
      const resp = await this.openai.chat.completions.create({
        model: 'gpt-4o-mini',
        temperature: 0.6,
        messages: [
          { role: 'system', content: sys },
          { role: 'user', content: user },
        ],
      });

      const out = (resp.choices?.[0]?.message?.content || '').trim();
      if (!out || out.length < 2) return fallback();
      return out;
    } catch {
      return fallback();
    }
  }

  private askService(services: any[], opts: { gentle: boolean }) {
    const list = servicesToTextShort(services);
    if (!list) return this.humanizeAsk('service');
    return opts.gentle ? `Hangi hizmet için yardımcı olayım?\n${list}` : `Hangi hizmeti istersiniz?\n${list}`;
  }

  // =========================
  // ✅ Öğrenen profil (DB’den)
  // =========================
  private async safeGetLearnedCustomerContext(
    tenantId: string,
    phone: string,
    services: any[],
  ): Promise<LearnedCustomerContext> {
    try {
      const customer = await this.prisma.customer
        .findUnique({
          where: { tenantId_phone: { tenantId, phone } } as any,
          select: { id: true, fullName: true } as any,
        })
        .catch(() => null);

      if (!customer?.id) {
        return { name: null, summary: '' };
      }

      const appts = await this.prisma.appointment
        .findMany({
          where: { tenantId, customerId: String(customer.id) } as any,
          orderBy: { startAt: 'desc' } as any,
          take: 20,
          select: {
            startAt: true,
            service: { select: { id: true, name: true } } as any,
            staff: { select: { id: true, fullName: true } } as any,
          } as any,
        })
        .catch(() => []);

      // en sık hizmet
      const serviceCount = new Map<string, { id: string; name: string; c: number }>();
      for (const a of appts || []) {
        const svcAny = (a as any)?.service as any;
        const sid = svcAny?.id ? String(svcAny.id) : '';
        const sname = svcAny?.name ? String(svcAny.name) : '';
        if (!sid || !sname) continue;
        const prev = serviceCount.get(sid) || { id: sid, name: sname, c: 0 };
        prev.c += 1;
        serviceCount.set(sid, prev);
      }
      const topSvc = [...serviceCount.values()].sort((x, y) => y.c - x.c)[0];

      // tercih saat aralığı (basit)
      let prefHour: string | null = null;
      if (appts?.length) {
        const buckets = new Map<string, number>(); // sabah/oglen/aksam
        for (const a of appts) {
          const d = a?.startAt ? new Date(a.startAt) : null;
          if (!d || isNaN(d.getTime())) continue;
          const tr = new Date(d.getTime() + IST_OFFSET_MS);
          const hh = tr.getUTCHours();
          const b = hh < 12 ? 'sabah' : hh < 18 ? 'öğlen' : 'akşam';
          buckets.set(b, (buckets.get(b) || 0) + 1);
        }
        prefHour = [...buckets.entries()].sort((a, b) => b[1] - a[1])[0]?.[0] || null;
      }

      const name = customer?.fullName ? String(customer.fullName) : null;

      // LLM'e gidecek kısa özet
      const summaryParts: string[] = [];
      if (name) summaryParts.push(`Müşteri adı: ${name}`);
      if (topSvc?.name) summaryParts.push(`Müşteri en sık: ${topSvc.name}`);
      if (prefHour) summaryParts.push(`Müşteri genelde: ${prefHour}`);

      return {
        customerId: String(customer.id),
        name,
        summary: summaryParts.join(' • '),
        topServiceId: topSvc?.id,
        topServiceName: topSvc?.name,
      };
    } catch {
      return { name: null, summary: '' };
    }
  }

  // =========================
  // Prisma helpers (enum-safe)
  // =========================
  private async findClashSafe(whereBase: any) {
    return await this.prisma.appointment.findFirst({
      where: whereBase,
      select: { id: true },
    });
  }

  private async precheckAndPrepareConfirm(opts: {
    tenantId: string;
    draft: BookingDraft;
  }): Promise<
    | { ok: true; summary: string }
    | { ok: false; code?: string; suggestions?: Array<{ startAt: string; endAt: string }> }
  > {
    const { tenantId, draft } = opts;

    if (!draft.serviceId || !draft.startAt || !draft.customerPhone) return { ok: false };

    const service = await this.prisma.services.findFirst({
      where: { id: String(draft.serviceId), tenantId },
      select: { id: true, name: true, duration: true, price: true } as any,
    });
    if (!service) return { ok: false };

    const staffRec = draft.staffId
      ? await (this.prisma as any).staff
          ?.findFirst({
            where: { id: String(draft.staffId), tenantId },
            select: { id: true, fullName: true } as any,
          })
          .catch(() => null)
      : null;

    const start = new Date(draft.startAt);
    const durationMinutes = Number((service as any).duration) || 30;
    const end = new Date(start.getTime() + durationMinutes * 60000);

    const startIso = String(draft.startAt);
    const endIso = toIstanbulIso(end);
    if (!isWithinWorkingHoursIso(startIso) || !isEndWithinWorkingHoursIso(endIso)) {
      const suggestions = suggestWorkingHourAlternatives(startIso, 5).map((s) => ({ startAt: s, endAt: s }));
      return { ok: false, code: 'OUT_OF_HOURS', suggestions };
    }

    const whereBase: any = {
      tenantId,
      startAt: { lt: end },
      endAt: { gt: start },
    };
    if (draft.staffId) whereBase.staffId = String(draft.staffId);

    const clash = await this.findClashSafe(whereBase);
    if (clash) {
      const suggestions = await this.suggestSlots({
        tenantId,
        staffId: draft.staffId ? String(draft.staffId) : undefined,
        startFrom: start,
        durationMinutes,
        stepMinutes: 15,
        maxSuggestions: 5,
        searchHours: 24,
      });
      return { ok: false, code: 'SLOT_TAKEN', suggestions };
    }

    const name = (draft.customerName || '').trim();
    const serviceName = String((service as any).name || 'Hizmet');
    const staffName = staffRec?.fullName ? String(staffRec.fullName) : null;

    const lines: string[] = [];
    lines.push('Randevu özeti:');
    lines.push(`• Hizmet: ${serviceName}${(service as any).price ? ` — ${(service as any).price}₺` : ''}`);
    if (staffName) lines.push(`• Personel: ${staffName}`);
    lines.push(`• Tarih/Saat: ${prettyIstanbul(draft.startAt)}`);
    if (name) lines.push(`• İsim: ${name}`);

    return { ok: true, summary: lines.join('\n') };
  }

  private async createAppointment(opts: {
    tenantId: string;
    draft: BookingDraft;
  }): Promise<
    | { ok: true; data: { appointmentId: string; startAt: string } }
    | { ok: false; code?: string; suggestions?: Array<{ startAt: string; endAt: string }> }
  > {
    const { tenantId, draft } = opts;

    try {
      const serviceId = String(draft.serviceId || '');
      const staffId = draft.staffId ? String(draft.staffId) : '';
      const startAt = String(draft.startAt || '');
      const customerPhone = String(draft.customerPhone || '');
      const customerName = draft.customerName ? String(draft.customerName) : null;

      if (!serviceId || !startAt || !customerPhone) return { ok: false };

      // ✅ isim zorunlu
      if (!customerName || customerName.trim().length < 2) return { ok: false, code: 'NEED_NAME' };

      // ✅ çalışma saatleri guard
      if (!isWithinWorkingHoursIso(startAt)) {
        const suggestions = suggestWorkingHourAlternatives(startAt, 5).map((s) => ({ startAt: s, endAt: s }));
        return { ok: false, code: 'OUT_OF_HOURS', suggestions };
      }

      const service = await this.prisma.services.findFirst({
        where: { id: serviceId, tenantId },
        select: { id: true, name: true, duration: true } as any,
      });
      if (!service) return { ok: false };

      const fullName = customerName.trim();

      const customer = await this.prisma.customer.upsert({
        where: { tenantId_phone: { tenantId, phone: customerPhone } },
        update: { fullName } as any,
        create: { tenantId, phone: customerPhone, fullName } as any,
        select: { id: true } as any,
      });

      const start = new Date(startAt);
      const durationMinutes = Number((service as any).duration) || 30;
      const end = new Date(start.getTime() + durationMinutes * 60000);

      const endIso = toIstanbulIso(end);
      if (!isEndWithinWorkingHoursIso(endIso)) {
        const suggestions = suggestWorkingHourAlternatives(startAt, 5).map((s) => ({ startAt: s, endAt: s }));
        return { ok: false, code: 'OUT_OF_HOURS', suggestions };
      }

      const whereBase: any = {
        tenantId,
        startAt: { lt: end },
        endAt: { gt: start },
      };
      if (staffId) whereBase.staffId = staffId;

      const clash = await this.findClashSafe(whereBase);
      if (clash) {
        const suggestions = await this.suggestSlots({
          tenantId,
          staffId: staffId || undefined,
          startFrom: start,
          durationMinutes,
          stepMinutes: 15,
          maxSuggestions: 5,
          searchHours: 24,
        });
        return { ok: false, code: 'SLOT_TAKEN', suggestions };
      }

      const baseData: any = {
        tenant: { connect: { id: tenantId } },
        startAt: start,
        endAt: end,
        customer: { connect: { id: customer.id } },
        service: { connect: { id: service.id } },
        ...(staffId ? { staff: { connect: { id: staffId } } } : {}),
      };

      // ✅ enum uyumlu create (status: 'scheduled', channel: 'WHATSAPP')
      let appt: any;
      try {
        appt = await this.prisma.appointment.create({
          data: {
            ...baseData,
            status: 'scheduled',
            channel: 'WHATSAPP',
          } as any,
          select: { id: true, startAt: true },
        });
      } catch (e: any) {
        this.logger.warn(`[createAppointment] status/channel failed, retry without them. ${e?.message || ''}`);
        appt = await this.prisma.appointment.create({
          data: baseData,
          select: { id: true, startAt: true },
        });
      }

      return {
        ok: true,
        data: { appointmentId: appt.id, startAt: appt.startAt.toISOString() },
      };
    } catch (e: any) {
      this.logger.error(`[createAppointment] failed hard: ${e?.message || e}`);
      return { ok: false, code: 'ERROR' };
    }
  }

  private async suggestSlots(opts: {
    tenantId: string;
    staffId?: string;
    startFrom: Date;
    durationMinutes: number;
    stepMinutes: number;
    maxSuggestions: number;
    searchHours: number;
  }) {
    const { tenantId, staffId, startFrom, durationMinutes, stepMinutes, maxSuggestions, searchHours } = opts;

    const suggestions: Array<{ startAt: string; endAt: string }> = [];
    const startMs = startFrom.getTime();
    const endMs = startMs + searchHours * 60 * 60 * 1000;

    for (let t = startMs; t < endMs && suggestions.length < maxSuggestions; t += stepMinutes * 60 * 1000) {
      const s = new Date(t);
      const e = new Date(t + durationMinutes * 60 * 1000);

      const sIso = toIstanbulIso(s);
      const eIso = toIstanbulIso(e);

      if (!isWithinWorkingHoursIso(sIso)) continue;
      if (!isEndWithinWorkingHoursIso(eIso)) continue;

      const whereBase: any = { tenantId, startAt: { lt: e }, endAt: { gt: s } };
      if (staffId) whereBase.staffId = staffId;

      const clash = await this.findClashSafe(whereBase);
      if (!clash) suggestions.push({ startAt: sIso, endAt: eIso });
    }

    return suggestions;
  }

  // =========================
  // LLM (FAQ / procedure)
  // =========================
  private async answerWithLLM(opts: {
    raw: string;
    business: any;
    services: any[];
    staff: any[];
    history: HistoryTurn[];
    mode: 'general' | 'procedure';
    focusService: null | { name: string; duration?: any; price?: any };
    avoidRepeat?: boolean;
    learnedCustomerSummary?: string;
  }): Promise<string> {
    if (!this.openai) return '';

    const { raw, business, services, staff, history, mode, focusService, avoidRepeat, learnedCustomerSummary } = opts;

    const servicesText = servicesToTextShort(services);
    const staffText = staffToTextShort(staff);

    const historyText =
      history && history.length
        ? history
            .slice(-8)
            .map((h) => `${h.role === 'user' ? 'Müşteri' : 'Asistan'}: ${h.text}`)
            .join('\n')
        : 'YOK';

    let system = `
Sen bir güzellik merkezi WhatsApp asistanısın. Türkçe konuş.
Kurallar:
- Cevaplar KISA olsun (maks 2-4 cümle).
- Durduk yere fiyat listesi / randevu yönlendirmesi yapma.
- Fiyat sadece müşteri sorarsa ver; mümkünse ilgili hizmete özel ver.
- Müşteri randevu/rezervasyon demeden randevu akışına sokma.
- Prosedür sorularında (acıtır mı, kaç seans, nasıl yapılır, sonrası bakım, yan etki, kimlere uygun değil) genel bilgi ver ama kesin tıbbi iddia yapma.
- Aynı mesajı tekrarlama. Gerekirse tek kısa soru sor.
- İnternete erişimin yok; "internetten baktım" gibi şeyler söyleme.
- Resmi dil kullanma; WhatsApp dili, doğal ve samimi yaz.
`.trim();

    if (mode === 'procedure') {
      system += `\n- Prosedür modunda yumuşak ve samimi bir dille yanıt ver; cevabın sonunda zorla randevu isteme.`;
    }
    if (avoidRepeat) {
      system += `\n- Aynı cümleleri tekrar etme; cevabı farklı yaz ve mümkünse yeni bir bakış açısı ekle.`;
    }

    const user = `
Mod: ${mode}
Müşteri mesajı: ${raw}

Müşteri geçmiş özet (varsa):
${learnedCustomerSummary || 'YOK'}

Odak hizmet (varsa): ${focusService ? JSON.stringify(focusService) : 'YOK'}
İşletme verisi: ${business ? JSON.stringify(business) : 'YOK'}

Hizmetler (kısa):
${servicesText || 'YOK'}

Personeller (kısa):
${staffText || 'YOK'}

Son konuşma geçmişi:
${historyText}
`.trim();

    try {
      const resp = await this.openai.chat.completions.create({
        model: 'gpt-4o-mini',
        temperature: avoidRepeat ? 0.7 : 0.6,
        messages: [
          { role: 'system', content: system },
          { role: 'user', content: user },
        ],
      });

      const out = (resp.choices?.[0]?.message?.content || '').trim();
      return out && out.length >= 2 ? out : '';
    } catch (e: any) {
      this.logger.warn(`[LLM] ${e?.message || e}`);
      return '';
    }
  }

  private procedureTemplateForService(serviceName: string, duration?: any, price?: any) {
    const parts: string[] = [];
    parts.push(`${serviceName} için genel olarak süreç kişiye göre değişebilir.`);
    if (duration != null) parts.push(`Seans süresi genelde ${duration} dk civarıdır.`);
    parts.push('Kaç seans gerektiği; bölge, kıl tipi ve cilt yapısına göre değişir.');
    const base = parts.join(' ');
    const priceLine = price != null ? `\nFiyat: ${price}₺` : '';
    return base + priceLine;
  }

